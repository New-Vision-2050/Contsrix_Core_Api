							"mode": "raw",
							"raw": "{\n    \"name\": \"Standard Annual Leave Policy\",\n    \"total_days\": 21,\n    \"day_type\": \"working_days\",\n    \"is_rollover_allowed\": true,\n    \"max_days_per_request\": 10,\n    \"upgrade_condition\": \"After 2 years of service\",\n    \"is_allow_half_day\": true\n}"
