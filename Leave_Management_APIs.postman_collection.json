	"item": [
		{
			"name": "🏖️ Public Holiday Management",
			"item": [
				{
					"name": "Get All Public Holidays",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{auth_token}}"
							},
							{
								"key": "Accept-Language",
								"value": "{{language}}",
								"description": "en for English, ar for Arabic"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/public-holidays",
							"host": ["{{base_url}}"],
							"path": ["api", "public-holidays"]
						},
						"description": "Retrieve all public holidays with date ranges, country information, and multilingual support."
					}
				},
				{
					"name": "Get Public Holiday by ID",
