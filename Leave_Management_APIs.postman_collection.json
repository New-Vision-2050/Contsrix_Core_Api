							}
						],
						"url": {
							"raw": "{{base_url}}/api/public-holidays/{{holiday_id}}",
							"host": ["{{base_url}}"],
							"path": ["api", "public-holidays", "{{holiday_id}}"]
						},
						"description": "Get specific public holiday details including date range and country relationship."
					}
				},
				{
					"name": "Create Public Holiday",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{auth_token}}"
							},
							{
								"key": "Accept-Language",
								"value": "{{language}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Christmas Holiday\",\n    \"country_id\": \"{{country_uuid}}\",\n    \"date_start\": \"2025-12-25\",\n    \"date_end\": \"2025-12-26\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/public-holidays",
							"host": ["{{base_url}}"],
							"path": ["api", "public-holidays"]
						},
						"description": "Create new public holiday with date range support. Fields:\n- name: Holiday name (required, max 255 chars)\n- country_id: Valid country UUID (required)\n- date_start: Start date in Y-m-d format (required)\n- date_end: End date >= start date (required)"
					}
				},
				{
					"name": "Update Public Holiday",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{auth_token}}"
							},
							{
								"key": "Accept-Language",
								"value": "{{language}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Extended Christmas Holiday\",\n    \"country_id\": \"{{country_uuid}}\",\n    \"date_start\": \"2025-12-24\",\n    \"date_end\": \"2025-12-27\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/public-holidays/{{holiday_id}}",
							"host": ["{{base_url}}"],
							"path": ["api", "public-holidays", "{{holiday_id}}"]
						},
						"description": "Update existing public holiday with enhanced date range validation and multilingual error messages."
					}
				},
				{
					"name": "Delete Public Holiday",
					"request": {
						"method": "DELETE",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{auth_token}}"
							},
							{
								"key": "Accept-Language",
								"value": "{{language}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/public-holidays/{{holiday_id}}",
							"host": ["{{base_url}}"],
							"path": ["api", "public-holidays", "{{holiday_id}}"]
						},
						"description": "Delete specific public holiday by UUID."
					}
				}
			],
			"description": "Enhanced Public Holiday APIs with date range support, country relationships, and Arabic/English validation messages."
		},
