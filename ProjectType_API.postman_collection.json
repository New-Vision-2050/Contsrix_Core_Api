{
	"info": {
		"_postman_id": "project-type-api-collection",
		"name": "ProjectType API",
		"description": "API endpoints for managing Project Types with hierarchical tree structure",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "List Project Types",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Accept",
						"value": "application/json",
						"type": "text"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{token}}",
						"type": "text"
					}
				],
				"url": {
					"raw": "{{url}}/project-types?page=1&per_page=15",
					"host": ["{{url}}"],
					"path": ["project-types"],
					"query": [
						{
							"key": "page",
							"value": "1",
							"description": "Page number"
						},
						{
							"key": "per_page",
							"value": "15",
							"description": "Items per page"
						}
					]
				},
				"description": "Get paginated list of all project types"
			}
		},
		{
			"name": "Get Root Project Types",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Accept",
						"value": "application/json",
						"type": "text"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{token}}",
						"type": "text"
					}
				],
				"url": {
					"raw": "{{url}}/project-types/roots",
					"host": ["{{url}}"],
					"path": ["project-types", "roots"]
				},
				"description": "Get all root level project types (parent_id is null)"
			}
		},
		{
			"name": "Get Project Type by ID",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Accept",
						"value": "application/json",
						"type": "text"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{token}}",
						"type": "text"
					}
				],
				"url": {
					"raw": "{{url}}/project-types/{{project_type_id}}",
					"host": ["{{url}}"],
					"path": ["project-types", "{{project_type_id}}"]
				},
				"description": "Get a specific project type by ID with parent and children relationships"
			}
		},
		{
			"name": "Get Direct Children",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Accept",
						"value": "application/json",
						"type": "text"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{token}}",
						"type": "text"
					}
				],
				"url": {
					"raw": "{{url}}/project-types/{{project_type_id}}/children",
					"host": ["{{url}}"],
					"path": ["project-types", "{{project_type_id}}", "children"]
				},
				"description": "Get direct children of a specific project type"
			}
		},
		{
			"name": "Create Project Type",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Accept",
						"value": "application/json",
						"type": "text"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{token}}",
						"type": "text"
					},
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"name\": \"Custom Project Type\",\n    \"icon\": \"custom-icon\",\n    \"parent_id\": null,\n    \"is_have_schema\": false,\n    \"is_active\": true\n}"
				},
				"url": {
					"raw": "{{url}}/project-types",
					"host": ["{{url}}"],
					"path": ["project-types"]
				},
				"description": "Create a new project type (is_created will be automatically set to true for user-created types)"
			}
		},
		{
			"name": "Create Child Project Type",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Accept",
						"value": "application/json",
						"type": "text"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{token}}",
						"type": "text"
					},
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"name\": \"Sub Project Type\",\n    \"icon\": \"sub-icon\",\n    \"parent_id\": 1,\n    \"is_have_schema\": true,\n    \"is_active\": true\n}"
				},
				"url": {
					"raw": "{{url}}/project-types",
					"host": ["{{url}}"],
					"path": ["project-types"]
				},
				"description": "Create a child project type under a parent (second level types can have schemas)"
			}
		},
		{
			"name": "Update Project Type",
			"request": {
				"method": "PUT",
				"header": [
					{
						"key": "Accept",
						"value": "application/json",
						"type": "text"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{token}}",
						"type": "text"
					},
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"name\": \"Updated Project Type Name\",\n    \"icon\": \"updated-icon\",\n    \"is_have_schema\": true,\n    \"is_active\": true\n}"
				},
				"url": {
					"raw": "{{url}}/project-types/{{project_type_id}}",
					"host": ["{{url}}"],
					"path": ["project-types", "{{project_type_id}}"]
				},
				"description": "Update an existing project type"
			}
		},
		{
			"name": "Delete Project Type",
			"request": {
				"method": "DELETE",
				"header": [
					{
						"key": "Accept",
						"value": "application/json",
						"type": "text"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{token}}",
						"type": "text"
					}
				],
				"url": {
					"raw": "{{url}}/project-types/{{project_type_id}}",
					"host": ["{{url}}"],
					"path": ["project-types", "{{project_type_id}}"]
				},
				"description": "Delete a project type (will cascade delete all children)"
			}
		},
		{
			"name": "Create Second Level Project Type",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Accept",
						"value": "application/json",
						"type": "text"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{token}}",
						"type": "text"
					},
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"name\": \"Residential Villas\",\n    \"icon\": \"villa-icon\",\n    \"parent_id\": 1,\n    \"reference_project_type_id\": null,\n    \"schema_ids\": [1, 2, 3],\n    \"is_active\": true\n}"
				},
				"url": {
					"raw": "{{url}}/project-types/second-level",
					"host": ["{{url}}"],
					"path": ["project-types", "second-level"]
				},
				"description": "Create a second level project type with schemas. Second level types are children of root types and can have schemas attached."
			}
		},
		{
			"name": "Get Project Types by Filter",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Accept",
						"value": "application/json",
						"type": "text"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{token}}",
						"type": "text"
					}
				],
				"url": {
					"raw": "{{url}}/project-types/filter?second_level=true&parent_id=1&is_have_schema=true",
					"host": ["{{url}}"],
					"path": ["project-types", "filter"],
					"query": [
						{
							"key": "second_level",
							"value": "true",
							"description": "Filter for second level project types only"
						},
						{
							"key": "parent_id",
							"value": "1",
							"description": "Filter by parent ID"
						},
						{
							"key": "is_have_schema",
							"value": "true",
							"description": "Filter by whether project type has schemas"
						},
						{
							"key": "is_created",
							"value": "true",
							"description": "Filter by user-created (true) or seeded (false)"
						}
					]
				},
				"description": "Get project types with various filters including second level, parent_id, is_have_schema, and is_created"
			}
		},
		{
			"name": "Get Schemas for Project Type",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Accept",
						"value": "application/json",
						"type": "text"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{token}}",
						"type": "text"
					}
				],
				"url": {
					"raw": "{{url}}/project-types/{{project_type_id}}/schemas",
					"host": ["{{url}}"],
					"path": ["project-types", "{{project_type_id}}", "schemas"]
				},
				"description": "Get schemas for a project type. If the project type is second level, returns its schemas. If it's a child of second level, returns parent's schemas. If it has a reference_project_type_id, returns reference type's schemas."
			}
		},
		{
			"name": "Export Project Types",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Accept",
						"value": "application/json",
						"type": "text"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{token}}",
						"type": "text"
					},
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"format\": \"xlsx\",\n    \"ids\": []\n}"
				},
				"url": {
					"raw": "{{url}}/project-types/export",
					"host": ["{{url}}"],
					"path": ["project-types", "export"]
				},
				"description": "Export project types to Excel or CSV format"
			}
		}
	],
	"variable": [
		{
			"key": "url",
			"value": "http://localhost/api/v1",
			"type": "string"
		},
		{
			"key": "token",
			"value": "your-bearer-token-here",
			"type": "string"
		},
		{
			"key": "project_type_id",
			"value": "1",
			"type": "string"
		}
	]
}
