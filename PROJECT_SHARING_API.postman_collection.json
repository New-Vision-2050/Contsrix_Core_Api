{
	"info": {
		"name": "Project Sharing API",
		"description": "API endpoints for sharing projects between companies",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{access_token}}",
				"type": "string"
			}
		]
	},
	"item": [
		{
			"name": "Company Management",
			"item": [
				{
					"name": "Get Company by Serial Number",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/companies/by-serial-number?serial_number=COMPANY-12345678",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "companies", "by-serial-number"],
							"query": [
								{
									"key": "serial_number",
									"value": "COMPANY-12345678",
									"description": "Serial number of the company to lookup"
								}
							]
						},
						"description": "Get company details by serial number (for sharing purposes)"
					},
					"response": []
				}
			]
		},
		{
			"name": "Schema Management",
			"item": [
				{
					"name": "List All Schemas",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/project-types/schemas?per_page=50&page=1&search=",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "project-types", "schemas"],
							"query": [
								{
									"key": "per_page",
									"value": "50",
									"description": "Results per page (default: 50)"
								},
								{
									"key": "page",
									"value": "1",
									"description": "Page number"
								},
								{
									"key": "search",
									"value": "",
									"description": "Search schemas by name"
								}
							]
						},
						"description": "Get all project schemas with pagination"
					},
					"response": []
				},
				{
					"name": "Get Schema by ID",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/project-types/schemas/:id",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "project-types", "schemas", ":id"],
							"variable": [
								{
									"key": "id",
									"value": "1",
									"description": "Schema ID"
								}
							]
						},
						"description": "Get a single schema by ID"
					},
					"response": []
				}
			]
		},
		{
			"name": "Project Sharing",
			"item": [
				{
					"name": "Share Project with Company",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"project_id\": \"{{project_id}}\",\n  \"company_serial_number\": \"COMPANY-12345678\",\n  \"schema_ids\": [1, 2, 3],\n  \"notes\": \"Please review this project\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/projects/sharing/share",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "projects", "sharing", "share"]
						},
						"description": "Share a project with another company by serial number"
					},
					"response": []
				},
				{
					"name": "Get Project Shares",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/projects/sharing/projects/:project_id/shares",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "projects", "sharing", "projects", ":project_id", "shares"],
							"variable": [
								{
									"key": "project_id",
									"value": "{{project_id}}",
									"description": "Project ID"
								}
							]
						},
						"description": "Get all companies a project is shared with (owner only)"
					},
					"response": []
				},
				{
					"name": "Get Pending Invitations",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/projects/sharing/invitations/pending",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "projects", "sharing", "invitations", "pending"]
						},
						"description": "Get all pending project share invitations for current company"
					},
					"response": []
				},
				{
					"name": "Get Shared Projects (Shared With Me)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/projects/sharing/shared-with-me",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "projects", "sharing", "shared-with-me"]
						},
						"description": "Get all projects shared with current company (accepted)"
					},
					"response": []
				},
				{
					"name": "Accept Share Invitation",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"share_id\": \"{{share_id}}\",\n  \"action\": \"accept\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/projects/sharing/invitations/respond",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "projects", "sharing", "invitations", "respond"]
						},
						"description": "Accept a share invitation"
					},
					"response": []
				},
				{
					"name": "Reject Share Invitation",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"share_id\": \"{{share_id}}\",\n  \"action\": \"reject\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/projects/sharing/invitations/respond",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "projects", "sharing", "invitations", "respond"]
						},
						"description": "Reject a share invitation"
					},
					"response": []
				},
				{
					"name": "Remove Share",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/projects/sharing/shares/:share_id",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "projects", "sharing", "shares", ":share_id"],
							"variable": [
								{
									"key": "share_id",
									"value": "{{share_id}}",
									"description": "Share ID to remove"
								}
							]
						},
						"description": "Remove a share (owner only)"
					},
					"response": []
				}
			]
		},
		{
			"name": "Project Employees",
			"item": [
				{
					"name": "Assign Employees to Project",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"project_id\": \"{{project_id}}\",\n  \"user_ids\": [\n    \"user-uuid-1\",\n    \"user-uuid-2\",\n    \"user-uuid-3\"\n  ]\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/projects/employees/assign",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "projects", "employees", "assign"]
						},
						"description": "Assign employees to a project"
					},
					"response": []
				},
				{
					"name": "Get Project Employees",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/projects/employees/project/:project_id",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "projects", "employees", "project", ":project_id"],
							"variable": [
								{
									"key": "project_id",
									"value": "{{project_id}}",
									"description": "Project ID"
								}
							]
						},
						"description": "Get all employees assigned to a project"
					},
					"response": []
				},
				{
					"name": "Remove Employee from Project",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/projects/employees/:id",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "projects", "employees", ":id"],
							"variable": [
								{
									"key": "id",
									"value": "",
									"description": "Project Employee ID"
								}
							]
						},
						"description": "Remove an employee from a project"
					},
					"response": []
				}
			]
		},
		{
			"name": "Project Management",
			"item": [
				{
					"name": "List Projects (Including Shared)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/projects?page=1&per_page=10",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "projects"],
							"query": [
								{
									"key": "page",
									"value": "1"
								},
								{
									"key": "per_page",
									"value": "10"
								}
							]
						},
						"description": "Get all projects (owned + accepted shared projects)"
					},
					"response": []
				}
			]
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8000",
			"type": "string"
		},
		{
			"key": "access_token",
			"value": "your_bearer_token_here",
			"type": "string"
		},
		{
			"key": "project_id",
			"value": "",
			"type": "string"
		},
		{
			"key": "share_id",
			"value": "",
			"type": "string"
		}
	]
}
