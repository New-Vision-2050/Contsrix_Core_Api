# Node modules & Composer vendor
/node_modules
/vendor
**/node_modules
**/vendor

# Laravel cache & storage
/storage
/bootstrap/cache

# Environment / sensitive files
/*.log

# VCS & IDE
/.git
/.github
/.gitlab*
/.idea
/.vscode
/*.iml

# Tests, docs, examples, local tooling that aren't needed in the runtime image
/tests
/docs
/coverage
/tmp
/*.md
/test_*.php
/*_test.php
/*.postman_collection.json
/openapi_*.yaml
/*.yaml

# Frontend build artifacts and runtime uploads (not needed in image)
/public/build
/public/storage
/public/uploads
/public/images
/public/assets
/public/hot
**/*.map

# Frontend sources that are not required at runtime (built assets are served from public)
/resources/js
/resources/ts
/resources/css
/resources/sass
/resources/assets
/resources/images
/resources/fonts
/resources/build

# OS / editor junk
**/.DS_Store
**/Thumbs.db
**/npm-debug.log*

# Large binaries and dumps that should never be in the image
**/*.zip
**/*.tar.gz
**/*.tgz
**/*.7z
**/*.rar
**/*.sql
**/*.bak
**/*.dump
**/*.mp4
**/*.mov
**/*.avi
**/*.mkv
**/*.csv
**/*.xlsx
**/*.xls
