{
	"info": {
		"_postman_id": "medical-insurance-category-api-collection",
		"name": "MedicalInsurance Categories API",
		"description": "CRUD API for managing categories (فئات) within a Medical Insurance policy",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "List Categories",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Accept",
						"value": "application/json",
						"type": "text"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{token}}",
						"type": "text"
					}
				],
				"url": {
					"raw": "{{url}}/medical-insurances/{{medical_insurance_id}}/categories?page=1&per_page=10",
					"host": ["{{url}}"],
					"path": ["medical-insurances", "{{medical_insurance_id}}", "categories"],
					"query": [
						{
							"key": "page",
							"value": "1",
							"description": "Page number"
						},
						{
							"key": "per_page",
							"value": "10",
							"description": "Items per page"
						}
					]
				},
				"description": "Get all categories (فئات البوليصة) for a specific medical insurance policy"
			},
			"response": [
				{
					"name": "Success Response",
					"status": "OK",
					"code": 200,
					"_postman_previewlanguage": "json",
					"header": [],
					"cookie": [],
					"body": "{\n    \"status\": true,\n    \"data\": [\n        {\n            \"id\": \"uuid-category-1\",\n            \"medical_insurance_id\": \"{{medical_insurance_id}}\",\n            \"name\": \"الفئة B — موظفون\",\n            \"type\": \"موظفون دائمون\",\n            \"coverage_limit\": \"500000.00\",\n            \"description\": \"تغطية شاملة داخل المملكة مع استثناء علاج خارجي\",\n            \"created_at\": \"2024-01-01 10:00:00\",\n            \"updated_at\": \"2024-01-01 10:00:00\"\n        },\n        {\n            \"id\": \"uuid-category-2\",\n            \"medical_insurance_id\": \"{{medical_insurance_id}}\",\n            \"name\": \"الفئة A — تنفيذية\",\n            \"type\": \"مدراء تنفيذيون\",\n            \"coverage_limit\": \"75000.00\",\n            \"description\": \"تغطية شاملة للمدراء التنفيذيين مع خدمات علاج خارج المملكة\",\n            \"created_at\": \"2024-01-01 10:00:00\",\n            \"updated_at\": \"2024-01-01 10:00:00\"\n        }\n    ],\n    \"pagination\": {\n        \"total\": 2,\n        \"per_page\": 10,\n        \"current_page\": 1,\n        \"last_page\": 1\n    }\n}"
				}
			]
		},
		{
			"name": "Create Category",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Accept",
						"value": "application/json",
						"type": "text"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{token}}",
						"type": "text"
					},
					{
						"key": "Content-Type",
						"value": "application/x-www-form-urlencoded",
						"type": "text"
					}
				],
				"body": {
					"mode": "urlencoded",
					"urlencoded": [
						{
							"key": "name",
							"value": "تامين بوبا",
							"type": "text",
							"description": "اسم الفئة - Category name (required, max 255)"
						},
						{
							"key": "type",
							"value": "موظفون دائمون",
							"type": "text",
							"description": "نوع الفئة - Category type (optional). Examples: موظفون دائمون | مدراء تنفيذيون | عمالة"
						},
						{
							"key": "coverage_limit",
							"value": "420000",
							"type": "text",
							"description": "الحد الاقصى للتغطية - Maximum coverage limit in SAR (required, numeric)"
						},
						{
							"key": "description",
							"value": "وصف مختصر لنطاق التغطية",
							"type": "text",
							"description": "وصف الفئة - Category description (required)"
						}
					]
				},
				"url": {
					"raw": "{{url}}/medical-insurances/{{medical_insurance_id}}/categories",
					"host": ["{{url}}"],
					"path": ["medical-insurances", "{{medical_insurance_id}}", "categories"]
				},
				"description": "Create a new category (فئة) for a medical insurance policy"
			},
			"response": [
				{
					"name": "Success Response",
					"status": "Created",
					"code": 201,
					"_postman_previewlanguage": "json",
					"header": [],
					"cookie": [],
					"body": "{\n    \"status\": true,\n    \"message\": \"Created successfully\",\n    \"data\": {\n        \"id\": \"uuid-new-category\",\n        \"medical_insurance_id\": \"{{medical_insurance_id}}\",\n        \"name\": \"تامين بوبا\",\n        \"type\": \"موظفون دائمون\",\n        \"coverage_limit\": \"420000.00\",\n        \"description\": \"وصف مختصر لنطاق التغطية\",\n        \"created_at\": \"2024-01-01 10:00:00\",\n        \"updated_at\": \"2024-01-01 10:00:00\"\n    }\n}"
				}
			]
		},
		{
