{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": [
        "laravel",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "ajcastro/eager-load-pivot-relations": "^0.3.0",
        "barryvdh/laravel-dompdf": "3.1",
        "guzzlehttp/guzzle": "^7.9",
        "ichtrojan/laravel-otp": "^2.0",
        "intervention/image": "^3.11",
        "kreait/laravel-firebase": "^5.8",
        "laravel/framework": "^11.31",
        "laravel/octane": "^2.5",
        "laravel/reverb": "^1.0",
        "laravel/telescope": "^5.7",
        "laravel/tinker": "^2.9",
        "league/flysystem-aws-s3-v3": "^3.29",
        "m-tech-stack/base-package": "^1.0",
        "m-tech-stack/rabbit-mq": "^1.0",
        "maatwebsite/excel": "^3.1",
        "mpdf/mpdf": "8.3",
        "nevadskiy/laravel-tree": "^0.6.0",
        "orangehill/iseed": "^3.1",
        "owen-it/laravel-auditing": "^14.0",
        "php-amqplib/php-amqplib": "^3.7",
        "propaganistas/laravel-phone": "^5.3",
        "ranium/laravel-seedonce": "^1.6",
        "sentry/sentry-laravel": "^4.13",
        "spatie/laravel-medialibrary": "^11.12",
        "spatie/laravel-permission": "^6.10",
        "spiral/roadrunner-cli": "^2.6",
        "spiral/roadrunner-http": "^3.5",
        "stancl/tenancy": "^3.9",
        "staudenmeir/eloquent-has-many-deep": "^1.7",
        "stevebauman/location": "^7.5",
        "tymon/jwt-auth": "^2.1",
        "vladimir-yuldashev/laravel-queue-rabbitmq": "^14.1"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pail": "^1.1",
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.26",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.1",
        "phpunit/phpunit": "^11.0.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/",
            "Modules\\": "modules/"
        },
        "files": [
            "app/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"npm run dev\" --names='server,queue,vite'"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": [
                "laravel/telescope",
                "laravel/pail"
            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        },
        "process-timeout": 2000
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
