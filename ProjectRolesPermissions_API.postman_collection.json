				{
					"name": "Compare Roles",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json",
								"type": "text"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{url}}/projects/{{project_id}}/roles/compare?role1={{role_id}}&role2={{role_id_2}}",
							"host": ["{{url}}"],
							"path": ["projects", "{{project_id}}", "roles", "compare"],
							"query": [
								{
									"key": "role1",
									"value": "{{role_id}}",
									"description": "First role ID to compare"
								},
								{
									"key": "role2",
									"value": "{{role_id_2}}",
									"description": "Second role ID to compare"
								}
							]
						},
						"description": "Compare permissions between two roles. Shows common permissions and differences."
					},
					"response": [
						{
							"name": "Success Response",
							"originalRequest": {
								"method": "GET",
								"header": [],
								"url": {
									"raw": "{{url}}/projects/{{project_id}}/roles/compare?role1=role-1&role2=role-2",
									"host": ["{{url}}"],
									"path": ["projects", "{{project_id}}", "roles", "compare"],
									"query": [
										{
											"key": "role1",
											"value": "role-1"
										},
										{
											"key": "role2",
											"value": "role-2"
										}
									]
								}
							},
							"status": "OK",
							"code": 200,
							"_postman_previewlanguage": "json",
							"header": [],
							"cookie": [],
							"body": "{\n    \"success\": true,\n    \"data\": {\n        \"project_id\": \"abc-123\",\n        \"role1\": {\n            \"id\": \"role-1\",\n            \"name\": \"Project Manager\",\n            \"permissions_count\": 25\n        },\n        \"role2\": {\n            \"id\": \"role-2\",\n            \"name\": \"Team Lead\",\n            \"permissions_count\": 15\n        },\n        \"comparison\": {\n            \"common_permissions\": [\n                \"project-management.project-management*employee.view\",\n                \"project-management.project-management*task.view\"\n            ],\n            \"common_count\": 10,\n            \"only_in_role1\": [\n                \"project-management.project-management*budget.approve\",\n                \"project-management.project-management*employee.delete\"\n            ],\n            \"only_in_role1_count\": 15,\n            \"only_in_role2\": [\n                \"project-management.project-management*task.assign\"\n            ],\n            \"only_in_role2_count\": 5\n        }\n    }\n}"
						}
					]
				},
