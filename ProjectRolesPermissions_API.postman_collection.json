				{
					"name": "Bulk Permission Check",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json",
								"type": "text"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}",
								"type": "text"
							},
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"permissions\": [\n        \"PROJECT_EMPLOYEE_CREATE\",\n        \"PROJECT_EMPLOYEE_UPDATE\",\n        \"PROJECT_EMPLOYEE_DELETE\",\n        \"PROJECT_ARCHIVE_VIEW\",\n        \"PROJECT_BUDGET_UPDATE\"\n    ]\n}"
						},
						"url": {
							"raw": "{{url}}/projects/{{project_id}}/check-permissions",
							"host": ["{{url}}"],
							"path": ["projects", "{{project_id}}", "check-permissions"]
						},
						"description": "Check multiple permissions at once for current user. Returns true/false for each permission. Uses config keys (e.g., PROJECT_EMPLOYEE_CREATE)."
					},
					"response": [
						{
							"name": "Success Response",
							"originalRequest": {
								"method": "POST",
								"header": [],
								"body": {
									"mode": "raw",
									"raw": "{\n    \"permissions\": [\n        \"PROJECT_EMPLOYEE_CREATE\",\n        \"PROJECT_ARCHIVE_VIEW\",\n        \"PROJECT_BUDGET_UPDATE\"\n    ]\n}"
								},
								"url": {
									"raw": "{{url}}/projects/{{project_id}}/check-permissions",
									"host": ["{{url}}"],
									"path": ["projects", "{{project_id}}", "check-permissions"]
								}
							},
							"status": "OK",
							"code": 200,
							"_postman_previewlanguage": "json",
							"header": [],
							"cookie": [],
							"body": "{\n    \"success\": true,\n    \"data\": {\n        \"project_id\": \"abc-123-def-456\",\n        \"user_id\": \"user-789-xyz-012\",\n        \"permissions\": {\n            \"PROJECT_EMPLOYEE_CREATE\": true,\n            \"PROJECT_ARCHIVE_VIEW\": true,\n            \"PROJECT_BUDGET_UPDATE\": false\n        }\n    }\n}"
						}
					]
				},
				{
					"name": "Get Users with Permission",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json",
								"type": "text"
							},
							{
								"key": "Authorization",
