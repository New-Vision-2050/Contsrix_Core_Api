					"raw": "{{url}}/medical-insurances?page=1&per_page=15&name=&policy_number=&employee_id=&status=",
					"host": ["{{url}}"],
					"path": ["medical-insurances"],
					"query": [
						{
							"key": "page",
							"value": "1",
							"description": "Page number"
						},
						{
							"key": "per_page",
							"value": "15",
							"description": "Items per page"
						},
						{
							"key": "name",
							"value": "",
