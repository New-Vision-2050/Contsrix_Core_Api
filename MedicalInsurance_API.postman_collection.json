						},
						{
							"key": "policy_number",
							"value": "",
							"description": "Search by policy number"
						},
						{
							"key": "employee_id",
							"value": "",
							"description": "Filter by employee ID (UUID)"
						},
						{
							"key": "status",
							"value": "",
							"description": "Filter by status (-1=suspended, 0=inactive, 1=active)"
						}
					]
				},
				"description": "Get paginated list of medical insurances with optional filters"
			},
			"response": []
		},
