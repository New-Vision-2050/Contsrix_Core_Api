{
	"info": {
		"_postman_id": "d7f9e4b8-5g6d-4b4f-9e6f-8d0f6g4c2g3e",
		"name": "CategoryWebsiteCMS",
		"description": "API endpoints for managing website categories with translatable names",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "List Categories",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{token}}",
						"type": "text"
					}
				],
				"url": {
					"raw": "{{base_url}}/api/v1/categories?page=1&per_page=10",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"v1",
						"categories"
					],
					"query": [
						{
							"key": "page",
							"value": "1"
						},
						{
							"key": "per_page",
							"value": "10"
						}
					]
				}
			},
			"response": []
		},
		{
			"name": "Get Category by ID",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{token}}",
						"type": "text"
					}
				],
				"url": {
					"raw": "{{base_url}}/api/v1/categories/{{category_id}}",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"v1",
						"categories",
						"{{category_id}}"
					]
				}
			},
			"response": []
		},
		{
			"name": "Create Category",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{token}}",
						"type": "text"
					},
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"name_ar\": \"أخبار التقنية\",\n    \"name_en\": \"Technology News\",\n    \"type_category_id\": \"{{type_category_id}}\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/api/v1/categories",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"v1",
						"categories"
					]
				}
			},
			"response": []
		},
		{
			"name": "Update Category",
			"request": {
				"method": "PUT",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{token}}",
						"type": "text"
					},
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"name_ar\": \"أخبار التقنية المحدثة\",\n    \"name_en\": \"Updated Technology News\",\n    \"type_category_id\": \"{{type_category_id}}\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/api/v1/categories/{{category_id}}",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"v1",
						"categories",
						"{{category_id}}"
					]
				}
			},
			"response": []
		},
		{
			"name": "Delete Category",
			"request": {
				"method": "DELETE",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{token}}",
						"type": "text"
					}
				],
				"url": {
					"raw": "{{base_url}}/api/v1/categories/{{category_id}}",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"v1",
						"categories",
						"{{category_id}}"
					]
				}
			},
			"response": []
		},
		{
			"name": "Export Categories",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{token}}",
						"type": "text"
					}
				],
				"body": {
					"mode": "formdata",
					"formdata": [
						{
							"key": "format",
							"value": "xlsx",
							"type": "text"
						}
					]
				},
				"url": {
					"raw": "{{base_url}}/api/v1/categories/export",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"v1",
						"categories",
						"export"
					]
				}
			},
			"response": []
		}
