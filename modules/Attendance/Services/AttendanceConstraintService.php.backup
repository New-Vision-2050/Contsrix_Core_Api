<?php

declare(strict_types=1);

namespace Modules\Attendance\Services;

use Modules\Attendance\Models\AttendanceConstraint;
use Modules\Attendance\Models\AttendanceConstraintViolation;
use Modules\Attendance\Models\Attendance;
use Modules\User\Models\User;
use Modules\Company\ManagementHierarchy\Models\ManagementHierarchy;
use Illuminate\Support\Collection;
use Illuminate\Support\Facades\Log;
use Carbon\Carbon;
use Modules\Attendance\DataClasses\MultiplePeriodsConfig;
use InvalidArgumentException;

class AttendanceConstraintService
{
    /**
     * Validate attendance against all applicable constraints.
     */
    public function validateAttendance(Attendance $attendance, array $requestData = []): array
    {
        $violations = [];
        $user = $attendance->user;

        // Get all applicable constraints for the user
        $constraints = $this->getApplicableConstraints($user);

        foreach ($constraints as $constraint) {
            $violation = $this->validateSingleConstraint($attendance, $constraint, $requestData);
            if ($violation) {
                $violations[] = $violation;
            }
        }

        return $violations;
    }

    /**
     * Get all constraints applicable to a user.
     */
    public function getApplicableConstraints(User $user): Collection
    {
        // Get user's branch if they belong to one
        $userBranch = $user->managementHierarchy;

        return AttendanceConstraint::where('company_id', $user->company_id)
            ->where(function ($query) use ($user, $userBranch) {
                // Company-wide constraints (no specific user, department, or branch)
                $query->whereNull('user_id')
                      ->whereNull('department_id')
                      ->whereNull('branch_id');

                // User-specific constraints
                $query->orWhere('user_id', $user->id);

                // Department-specific constraints
                if ($user->department_id) {
                    $query->orWhere('department_id', $user->department_id);
                }

                // Branch-specific constraints
                if ($userBranch) {
                    $query->orWhere('branch_id', $userBranch->id);

                    // Include inherited constraints from parent branches
                    $query->orWhere(function ($subQuery) use ($userBranch) {
                        $subQuery->where('inherit_from_parent', true)
                                 ->whereIn('branch_id', $this->getParentBranchIds($userBranch));
                    });
                }
            })
            ->active()
            ->byPriority()
            ->get()
            ->filter(function ($constraint) {
                return $this->isConstraintValidForDate($constraint);
            });
    }

    /**
     * Get parent branch IDs for inheritance.
     */
    private function getParentBranchIds(ManagementHierarchy $branch): array
    {
        $parentIds = [];
        $currentBranch = $branch;

        // Traverse up the hierarchy to get all parent branches
        while ($currentBranch->parent_id) {
            $parent = ManagementHierarchy::find($currentBranch->parent_id);
            if ($parent && $parent->type === 'branch') {
                $parentIds[] = $parent->id;
                $currentBranch = $parent;
            } else {
                break;
            }
        }

        return $parentIds;
    }

    /**
     * Check if constraint is valid for the current date.
     */
    private function isConstraintValidForDate(AttendanceConstraint $constraint): bool
    {
        $today = Carbon::today();

        if ($constraint->start_date && $today->lt($constraint->start_date)) {
            return false;
        }

        if ($constraint->end_date && $today->gt($constraint->end_date)) {
            return false;
        }

        return true;
    }

    /**
     * Get constraints for a specific branch (including inherited).
     */
    public function getConstraintsForBranch(string $branchId, string $companyId): Collection
    {
        $branch = ManagementHierarchy::find($branchId);

        if (!$branch || $branch->type !== 'branch') {
            return collect();
        }

        return AttendanceConstraint::where('company_id', $companyId)
            ->applicableToBranch($branchId)
            ->active()
            ->byPriority()
            ->get()
            ->filter(function ($constraint) {
                return $this->isConstraintValidForDate($constraint);
            });
    }

    /**
     * Validate a single constraint against attendance.
     */
    protected function validateSingleConstraint(Attendance $attendance, AttendanceConstraint $constraint, array $requestData): ?array
    {
        switch ($constraint->constraint_type) {
            case AttendanceConstraint::TYPE_LOCATION:
                return $this->validateLocationConstraint($attendance, $constraint, $requestData);

            case AttendanceConstraint::TYPE_TIME:
                return $this->validateTimeConstraint($attendance, $constraint, $requestData);

            case AttendanceConstraint::TYPE_DEVICE:
                return $this->validateDeviceConstraint($attendance, $constraint, $requestData);

            case AttendanceConstraint::TYPE_ROLE:
                return $this->validateRoleConstraint($attendance, $constraint, $requestData);

            case AttendanceConstraint::TYPE_BEHAVIORAL:
                return $this->validateBehavioralConstraint($attendance, $constraint, $requestData);

            case AttendanceConstraint::TYPE_SECURITY:
                return $this->validateSecurityConstraint($attendance, $constraint, $requestData);

            case AttendanceConstraint::TYPE_COMPLIANCE:
                return $this->validateComplianceConstraint($attendance, $constraint, $requestData);

            default:
                return null;
        }
    }

    /**
     * Validate location-based constraints.
     */
    protected function validateLocationConstraint(Attendance $attendance, AttendanceConstraint $constraint, array $requestData): ?array
    {
        $config = $constraint->constraint_config;

        switch ($constraint->constraint_name) {
            case AttendanceConstraint::LOCATION_GEOFENCING:
                return $this->validateGeofencing($attendance, $config, $requestData);

            case AttendanceConstraint::LOCATION_IP_RESTRICTION:
                return $this->validateIpRestriction($attendance, $config, $requestData);

            case AttendanceConstraint::LOCATION_OFFICE_VERIFICATION:
                return $this->validateOfficeVerification($attendance, $config, $requestData);

            default:
                return null;
        }
    }

    /**
     * Validate geofencing constraint.
     */
    protected function validateGeofencing(Attendance $attendance, array $config, array $requestData): ?array
    {
        if (!isset($requestData['latitude']) || !isset($requestData['longitude'])) {
            return [
                'constraint_type' => AttendanceConstraint::TYPE_LOCATION,
                'violation_type' => AttendanceConstraintViolation::TYPE_LOCATION_VIOLATION,
                'severity' => AttendanceConstraintViolation::SEVERITY_HIGH,
                'message' => 'Location data required for geofencing validation',
                'details' => ['missing_location_data' => true]
            ];
        }

        $userLat = (float) $requestData['latitude'];
        $userLng = (float) $requestData['longitude'];

        foreach ($config['allowed_zones'] ?? [] as $zone) {
            $distance = $this->calculateDistance(
                $userLat, $userLng,
                $zone['latitude'], $zone['longitude']
            );

            if ($distance <= $zone['radius']) {
                return null; // Within allowed zone
            }
        }

        return [
            'constraint_type' => AttendanceConstraint::TYPE_LOCATION,
            'violation_type' => AttendanceConstraintViolation::TYPE_LOCATION_VIOLATION,
            'severity' => AttendanceConstraintViolation::SEVERITY_HIGH,
            'message' => 'User location outside allowed geofenced areas',
            'details' => [
                'user_location' => ['lat' => $userLat, 'lng' => $userLng],
                'allowed_zones' => $config['allowed_zones']
            ]
        ];
    }

    /**
     * Validate IP restriction constraint.
     */
    protected function validateIpRestriction(Attendance $attendance, array $config, array $requestData): ?array
    {
        $userIp = $requestData['ip_address'] ?? request()->ip();
        $allowedIps = $config['allowed_ips'] ?? [];
        $allowedRanges = $config['allowed_ranges'] ?? [];

        // Check exact IP matches
        if (in_array($userIp, $allowedIps)) {
            return null;
        }

        // Check IP ranges
        foreach ($allowedRanges as $range) {
            if ($this->ipInRange($userIp, $range)) {
                return null;
            }
        }

        return [
            'constraint_type' => AttendanceConstraint::TYPE_LOCATION,
            'violation_type' => AttendanceConstraintViolation::TYPE_LOCATION_VIOLATION,
            'severity' => AttendanceConstraintViolation::SEVERITY_MEDIUM,
            'message' => 'Access from unauthorized IP address',
            'details' => [
                'user_ip' => $userIp,
                'allowed_ips' => $allowedIps,
                'allowed_ranges' => $allowedRanges
            ]
        ];
    }

    /**
     * Validate time-based constraints.
     */
    protected function validateTimeConstraint(Attendance $attendance, AttendanceConstraint $constraint, array $requestData): ?array
    {
        $config = $constraint->constraint_config;

        switch ($constraint->constraint_name) {
            case AttendanceConstraint::TIME_SHIFT_ENFORCEMENT:
                return $this->validateShiftEnforcement($attendance, $config);

            case AttendanceConstraint::TIME_EARLY_PREVENTION:
                return $this->validateEarlyPrevention($attendance, $config);

            case AttendanceConstraint::TIME_OVERTIME_APPROVAL:
                return $this->validateOvertimeApproval($attendance, $config);

            case AttendanceConstraint::TIME_MULTIPLE_PERIODS:
                return $this->validateMultiplePeriods($attendance, $config);

            case AttendanceConstraint::TIME_LATE_CLOCK_OUT:
                return $this->validateLateClockOut($attendance, $config);

            case AttendanceConstraint::TIME_BREAK_TIME_LIMITS:
                // This is validated at the end of a break, not here
                return null;

            default:
                return null;
        }
    }

    /**
     * Validate shift enforcement constraint.
     */
    protected function validateShiftEnforcement(Attendance $attendance, array $config): ?array
    {
        $shiftStart = Carbon::parse($config['shift_start_time']);
        $shiftEnd = Carbon::parse($config['shift_end_time']);
        $gracePeriod = $config['grace_period_minutes'] ?? 0;

        $clockInTime = $attendance->clock_in_time;

        if ($clockInTime->lt($shiftStart->subMinutes($gracePeriod))) {
            return [
                'constraint_type' => AttendanceConstraint::TYPE_TIME,
                'violation_type' => AttendanceConstraintViolation::TYPE_TIME_VIOLATION,
                'severity' => AttendanceConstraintViolation::SEVERITY_MEDIUM,
                'message' => 'Clock-in time is before allowed shift start time',
                'details' => [
                    'clock_in_time' => $clockInTime->toISOString(),
                    'shift_start_time' => $shiftStart->toISOString(),
                    'grace_period_minutes' => $gracePeriod
                ]
            ];
        }

        return null;
    }

    /**
     * Validate late clock-out constraint.
     */
    protected function validateLateClockOut(Attendance $attendance, array $config): ?array
    {
        if (!$attendance->clock_out_time) {
            return null; // Cannot validate if not clocked out
        }

        $maxDuration = $config['max_work_duration_hours'] ?? 8;
        $workDurationHours = $attendance->clock_in_time->diffInMinutes($attendance->clock_out_time) / 60;

        if ($workDurationHours > $maxDuration) {
            return [
                'constraint_type' => AttendanceConstraint::TYPE_TIME,
                'violation_type' => AttendanceConstraintViolation::TYPE_TIME_VIOLATION,
                'severity' => AttendanceConstraintViolation::SEVERITY_MEDIUM,
                'message' => 'Work session exceeded maximum allowed duration.',
                'details' => [
                    'work_duration_hours' => round($workDurationHours, 2),
                    'max_work_duration_hours' => $maxDuration,
                ],
            ];
        }

        return null;
    }

    /**
     * Validate break time limits when a break ends.
     */
    public function validateBreakEnd(Attendance $attendance): ?array
    {
        if (!$attendance->break_start_time || !$attendance->break_end_time) {
            return null; // Cannot validate if break times are not set
        }

        $user = $attendance->user;
        $constraints = $this->getApplicableConstraints($user)
            ->where('constraint_name', AttendanceConstraint::TIME_BREAK_TIME_LIMITS);

        foreach ($constraints as $constraint) {
            $config = $constraint->constraint_config;
            $minDuration = $config['min_break_minutes'] ?? 0;
            $maxDuration = $config['max_break_minutes'] ?? 60;
            $breakDuration = $attendance->break_start_time->diffInMinutes($attendance->break_end_time);

            if ($breakDuration < $minDuration || $breakDuration > $maxDuration) {
                return [
                    'constraint_id' => $constraint->id,
                    'constraint_type' => AttendanceConstraint::TYPE_TIME,
                    'violation_type' => AttendanceConstraintViolation::TYPE_TIME_VIOLATION,
                    'severity' => AttendanceConstraintViolation::SEVERITY_LOW,
                    'message' => 'Break duration is outside the allowed limits.',
                    'details' => [
                        'break_duration_minutes' => $breakDuration,
                        'min_break_minutes' => $minDuration,
                        'max_break_minutes' => $maxDuration,
                    ],
                ];
            }
        }

        return null;
    }

    /**
     * Validate device-based constraints.
     */
    protected function validateDeviceConstraint(Attendance $attendance, AttendanceConstraint $constraint, array $requestData): ?array
    {
        $config = $constraint->constraint_config;

        switch ($constraint->constraint_name) {
            case AttendanceConstraint::DEVICE_AUTHORIZED_ONLY:
                return $this->validateAuthorizedDevice($attendance, $config, $requestData);

            case AttendanceConstraint::DEVICE_SINGLE_POLICY:
                return $this->validateSingleDevicePolicy($attendance, $config, $requestData);

            default:
                return null;
        }
    }

    /**
     * Create a constraint violation record.
     */
    public function createViolation(Attendance $attendance, AttendanceConstraint $constraint, array $violationData): AttendanceConstraintViolation
    {
        return AttendanceConstraintViolation::create([
            'company_id' => $attendance->company_id,
            'user_id' => $attendance->user_id,
            'attendance_id' => $attendance->id,
            'constraint_id' => $constraint->id,
            'violation_type' => $violationData['violation_type'],
            'violation_details' => $violationData['details'] ?? [],
            'severity_level' => $violationData['severity'],
            'status' => AttendanceConstraintViolation::STATUS_PENDING,
            'auto_resolved' => false,
            'notification_sent' => false,
        ]);
    }

    /**
     * Process all violations and create records.
     */
    public function processViolations(Attendance $attendance, array $violations): Collection
    {
        $violationRecords = collect();

        foreach ($violations as $violation) {
            $constraint = AttendanceConstraint::find($violation['constraint_id']);
            if ($constraint) {
                $violationRecord = $this->createViolation($attendance, $constraint, $violation);
                $violationRecords->push($violationRecord);

                // Log the violation
                Log::warning('Attendance constraint violation detected', [
                    'user_id' => $attendance->user_id,
                    'constraint_type' => $violation['constraint_type'],
                    'violation_type' => $violation['violation_type'],
                    'severity' => $violation['severity'],
                    'message' => $violation['message']
                ]);
            }
        }

        return $violationRecords;
    }

    /**
     * Calculate distance between two coordinates (Haversine formula).
     */
    protected function calculateDistance(float $lat1, float $lng1, float $lat2, float $lng2): float
    {
        $earthRadius = 6371000; // Earth's radius in meters

        $dLat = deg2rad($lat2 - $lat1);
        $dLng = deg2rad($lng2 - $lng1);

        $a = sin($dLat / 2) * sin($dLat / 2) +
             cos(deg2rad($lat1)) * cos(deg2rad($lat2)) *
             sin($dLng / 2) * sin($dLng / 2);

        $c = 2 * atan2(sqrt($a), sqrt(1 - $a));

        return $earthRadius * $c;
    }

    /**
     * Check if IP is within a given range.
     */
    protected function ipInRange(string $ip, string $range): bool
    {
        if (strpos($range, '/') === false) {
            return $ip === $range;
        }

        list($subnet, $mask) = explode('/', $range);

        $ipLong = ip2long($ip);
        $subnetLong = ip2long($subnet);
        $maskLong = -1 << (32 - $mask);

        return ($ipLong & $maskLong) === ($subnetLong & $maskLong);
    }

    /**
     * Validate attendance data against applicable constraints without an Attendance object.
     * Used for pre-validation before clock-in.
     *
     * @param array $attendanceData Array containing user_id, clock_in_time, and other attendance data
     * @return array List of constraint violations if any
     */
    public function validateAttendanceData(array $attendanceData): array
    {
        $violations = [];
        $user = User::find($attendanceData['user_id']);

        if (!$user) {
            return [
                [
                    'violation_type' => 'system_error',
                    'severity' => AttendanceConstraintViolation::SEVERITY_HIGH,
                    'message' => 'User not found',
                    'details' => ['user_id' => $attendanceData['user_id']]
                ]
            ];
        }

        // Get all applicable constraints for the user
        $constraints = $this->getApplicableConstraints($user);

        foreach ($constraints as $constraint) {
            // Create a temporary attendance object for validation
            $tempAttendance = new Attendance([
                'company_id' => $user->company_id,
                'user_id' => $user->id,
                'clock_in_time' => Carbon::parse($attendanceData['clock_in_time']),
                'clock_in_location' => $attendanceData['clock_in_location'] ?? null,
                'ip_address' => $attendanceData['ip_address'] ?? null
            ]);

            $violation = $this->validateSingleConstraint($tempAttendance, $constraint, $attendanceData);

            if ($violation) {
                $violation['constraint_id'] = $constraint->id;
                $violations[] = $violation;
            }
        }

        return $violations;
    }

    /**
     * Validate multiple periods constraint.
     */
    protected function validateMultiplePeriods(Attendance $attendance, array $config): ?array
    {
        try {
            // Parse config using data class for type safety
            $multiplePeriodsConfig = MultiplePeriodsConfig::fromArray($config);
        } catch (InvalidArgumentException $e) {
            return [
                'constraint_type' => AttendanceConstraint::TYPE_TIME,
                'violation_type' => AttendanceConstraintViolation::TYPE_TIME_VIOLATION,
                'severity' => AttendanceConstraintViolation::SEVERITY_HIGH,
                'message' => 'Invalid multiple periods configuration: ' . $e->getMessage(),
                'details' => [
                    'config_error' => $e->getMessage(),
                    'clock_in_time' => $attendance->clock_in_time->format('H:i'),
                ],
            ];
        }

        $clockInTime = $attendance->clock_in_time;
        $dayOfWeek = strtolower($clockInTime->format('l')); // e.g., 'sunday', 'monday'

        // Get the day schedule
        $daySchedule = $multiplePeriodsConfig->getDaySchedule($dayOfWeek);

        // Check if the day is configured
        if ($daySchedule === null) {
            return [
                'constraint_type' => AttendanceConstraint::TYPE_TIME,
                'violation_type' => AttendanceConstraintViolation::TYPE_TIME_VIOLATION,
                'severity' => AttendanceConstraintViolation::SEVERITY_HIGH,
                'message' => "No schedule configured for {$dayOfWeek}",
                'details' => [
                    'day_of_week' => $dayOfWeek,
                    'clock_in_time' => $clockInTime->format('H:i'),
                    'configured_days' => $multiplePeriodsConfig->getEnabledDays(),
                ],
            ];
        }

        // Check if the day is enabled
        if (!$daySchedule->enabled) {
            return [
                'constraint_type' => AttendanceConstraint::TYPE_TIME,
                'violation_type' => AttendanceConstraintViolation::TYPE_TIME_VIOLATION,
                'severity' => AttendanceConstraintViolation::SEVERITY_HIGH,
                'message' => "Attendance not allowed on {$dayOfWeek}",
                'details' => [
                    'day_of_week' => $dayOfWeek,
                    'clock_in_time' => $clockInTime->format('H:i'),
                    'enabled_days' => $multiplePeriodsConfig->getEnabledDays(),
                ],
            ];
        }

        // Check if clock-in time falls within any allowed period
        $clockInTimeString = $clockInTime->format('H:i');

        foreach ($daySchedule->periods as $period) {
            if ($this->isTimeWithinPeriod($clockInTimeString, $period)) {
                // Valid clock-in time found
                return null;
            }
        }

        // No valid period found
        return [
            'constraint_type' => AttendanceConstraint::TYPE_TIME,
            'violation_type' => AttendanceConstraintViolation::TYPE_TIME_VIOLATION,
            'severity' => AttendanceConstraintViolation::SEVERITY_MEDIUM,
            'message' => "Clock-in time outside allowed periods for {$dayOfWeek}",
            'details' => [
                'day_of_week' => $dayOfWeek,
                'clock_in_time' => $clockInTimeString,
                'allowed_periods' => array_map(function($period) {
                    return [
                        'name' => $period->name,
                        'start_time' => $period->startTime,
                        'end_time' => $period->endTime,
                        'spans_next_day' => $period->extends_to_next_day,
                        'effective_start' => $period->getEffectiveStartTime(),
                        'effective_end' => $period->getEffectiveEndTime(),
                    ];
                }, $daySchedule->periods),
            ],
        ];
    }

    /**
     * Check if a time falls within a period (including grace periods).
     */
    protected function isTimeWithinPeriod(string $timeString, $period): bool
    {
        // Convert time to minutes since midnight
        $timeMinutes = $this->timeToMinutes($timeString);

        // Get effective period boundaries including grace periods
        $effectiveStartMinutes = $this->timeToMinutes($period->getEffectiveStartTime());
        $effectiveEndMinutes = $this->timeToMinutes($period->getEffectiveEndTime());

        if ($period->extends_to_next_day) {
            // For cross-day periods, check if time is after start OR before end
            return $timeMinutes >= $effectiveStartMinutes || $timeMinutes <= $effectiveEndMinutes;
        } else {
            // For same-day periods, check if time is between start and end
            // Handle grace period overflow/underflow
            if ($effectiveStartMinutes > $effectiveEndMinutes) {
                // Grace periods caused overflow (e.g., 23:45 to 00:15 next day)
                return $timeMinutes >= $effectiveStartMinutes || $timeMinutes <= $effectiveEndMinutes;
            } else {
                return $timeMinutes >= $effectiveStartMinutes && $timeMinutes <= $effectiveEndMinutes;
            }
        }
    }

    /**
     * Additional validation methods would be implemented here for:
     * - validateOfficeVerification
     */

    /**
     * Validate early prevention constraint.
     * Prevents employees from clocking out before their scheduled end time.
     *
     * @param Attendance $attendance The attendance record to validate
     * @param array $config The constraint configuration
     * @return bool|array Returns false if no violation, or violation details if constraint is violated
     */
    protected function validateEarlyPrevention(Attendance $attendance, array $config): bool|array
    {
        if (!$attendance->clock_out_time) {
            return false;
        }
        $clockOutTime = Carbon::parse($attendance->clock_out_time);
        $scheduledEndTime = null;
        if (isset($config['scheduled_end_time'])) {
            $scheduledEndTime = Carbon::parse($config['scheduled_end_time']);
        } elseif (isset($config['work_hours']) && is_numeric($config['work_hours'])) {
            $workHoursInMinutes = (float)$config['work_hours'] * 60;
            $scheduledEndTime = Carbon::parse($attendance->clock_in_time)->addMinutes($workHoursInMinutes);
        } else {
            return false;
        }
        $gracePeriodMinutes = isset($config['grace_period_minutes']) ? (int)$config['grace_period_minutes'] : 0;
        $earliestAllowedDeparture = $scheduledEndTime->copy()->subMinutes($gracePeriodMinutes);
        if ($clockOutTime->lt($earliestAllowedDeparture)) {
            $minutesEarly = $earliestAllowedDeparture->diffInMinutes($clockOutTime);
            return [
                'constraint_type' => AttendanceConstraint::TIME_EARLY_PREVENTION,
                'severity' => $this->getSeverityFromConfig($config),
                'message' => "Early departure detected. Left {$minutesEarly} minutes before scheduled end time.",
                'details' => [
                    'clock_out_time' => $clockOutTime->toDateTimeString(),
                    'scheduled_end_time' => $scheduledEndTime->toDateTimeString(),
                    'earliest_allowed_departure' => $earliestAllowedDeparture->toDateTimeString(),
                    'minutes_early' => $minutesEarly
                ]
            ];
        }

        return false;
    }

    /**
     * Validate overtime approval constraint.
     * Checks if overtime work has been properly approved.
     *
     * @param Attendance $attendance The attendance record to validate
     * @param array $config The constraint configuration
     * @return bool|array Returns false if no violation, or violation details if constraint is violated
     */
    protected function validateOvertimeApproval(Attendance $attendance, array $config): bool|array
    {
        // Check if overtime exists
        if (!isset($attendance->overtime_minutes) || $attendance->overtime_minutes <= 0) {
            return false;
        }

        // Calculate total work time in minutes
        $clockInTime = Carbon::parse($attendance->clock_in_time);
        $clockOutTime = Carbon::parse($attendance->clock_out_time);
        $totalWorkMinutes = $clockInTime->diffInMinutes($clockOutTime);

        // Subtract break time if applicable
        if ($attendance->total_break_time) {
            $totalWorkMinutes -= $attendance->total_break_time;
        }

        // Get standard work hours from config (default to 8 hours if not specified)
        $standardWorkHours = isset($config['standard_work_hours']) ? (float)$config['standard_work_hours'] : 8.0;
        $standardWorkMinutes = $standardWorkHours * 60;

        // Get overtime threshold in minutes (default to standard work hours if not specified)
        $overtimeThresholdMinutes = isset($config['overtime_threshold_minutes'])
            ? (int)$config['overtime_threshold_minutes']
            : $standardWorkMinutes;

        // Check if work time exceeds overtime threshold
        if ($totalWorkMinutes > $overtimeThresholdMinutes) {
            // Check if overtime is approved
            $overtimeApproved = isset($attendance->overtime_approved) && $attendance->overtime_approved;

            if (!$overtimeApproved) {
                $overtimeMinutes = $totalWorkMinutes - $overtimeThresholdMinutes;
                $overtimeHours = round($overtimeMinutes / 60, 2);

                return [
                    'constraint_type' => AttendanceConstraint::TIME_OVERTIME_APPROVAL,
                    'severity' => $this->getSeverityFromConfig($config),
                    'message' => "Unapproved overtime detected. {$overtimeHours} hours of overtime without approval.",
                    'details' => [
                        'clock_in_time' => $clockInTime->toDateTimeString(),
                        'clock_out_time' => $clockOutTime->toDateTimeString(),
                        'total_work_minutes' => $totalWorkMinutes,
                        'standard_work_minutes' => $standardWorkMinutes,
                        'overtime_minutes' => $overtimeMinutes,
                        'overtime_hours' => $overtimeHours
                    ]
                ];
            }
        }

        return false;
    }

    /**
     * Validates if the device used for attendance is authorized.
     *
     * @param Attendance $attendance The attendance record to validate
     * @param array $config The constraint configuration
     * @return bool|array Returns false if no violation, or violation details if constraint is violated
     */
    protected function validateAuthorizedDevice(Attendance $attendance, array $config): bool|array
    {
        // Skip validation if device info is not available
        if (empty($attendance->device_id) || empty($attendance->device_info)) {
            return false;
        }

        // Get list of authorized devices from config
        $authorizedDevices = $config['authorized_devices'] ?? [];

        // If no authorized devices specified, no violation
        if (empty($authorizedDevices)) {
            return false;
        }

        // Check if the device is in the authorized list
        $deviceAuthorized = false;
        foreach ($authorizedDevices as $device) {
            // Check device ID match
            if (isset($device['device_id']) && $device['device_id'] === $attendance->device_id) {
                $deviceAuthorized = true;
                break;
            }

            // Check device fingerprint match if available
            if (isset($device['fingerprint']) && isset($attendance->device_info['fingerprint']) &&
                $device['fingerprint'] === $attendance->device_info['fingerprint']) {
                $deviceAuthorized = true;
                break;
            }
        }

        if (!$deviceAuthorized) {
            return [
                'constraint_type' => AttendanceConstraint::DEVICE_AUTHORIZED_ONLY,
                'severity' => $this->getSeverityFromConfig($config),
                'message' => 'Unauthorized device used for attendance.',
                'details' => [
                    'device_id' => $attendance->device_id,
                    'device_info' => $attendance->device_info
                ]
            ];
        }

        return false;
    }

    /**
     * Validates if the user is following the single device policy.
     *
     * @param Attendance $attendance The attendance record to validate
     * @param array $config The constraint configuration
     * @return bool|array Returns false if no violation, or violation details if constraint is violated
     */
    protected function validateSingleDevicePolicy(Attendance $attendance, array $config): bool|array
    {
        // Skip validation if device info is not available
        if (empty($attendance->device_id) || empty($attendance->user_id)) {
            return false;
        }

        // Get time period to check (default: last 7 days)
        $daysPeriod = $config['days_period'] ?? 7;
        $startDate = Carbon::now()->subDays($daysPeriod)->startOfDay();

        // Get user's previous attendance records within the period
        $previousAttendances = app(AttendanceRepository::class)->getUserAttendanceInPeriod(
            $attendance->user_id,
            $startDate->toDateString(),
            Carbon::now()->toDateString()
        );

        // Skip if this is the first attendance record
        if ($previousAttendances->isEmpty()) {
            return false;
        }

        // Check if user has used a different device in the period
        $usedDevices = collect();
        foreach ($previousAttendances as $prevAttendance) {
            if (!empty($prevAttendance->device_id) && $prevAttendance->id !== $attendance->id) {
                $usedDevices->push($prevAttendance->device_id);
            }
        }

        // Add current device
        $usedDevices->push($attendance->device_id);

        // Check if more than one unique device was used
        $uniqueDevices = $usedDevices->unique();
        if ($uniqueDevices->count() > 1) {
            return [
                'constraint_type' => AttendanceConstraint::DEVICE_SINGLE_POLICY,
                'severity' => $this->getSeverityFromConfig($config),
                'message' => 'Multiple devices used for attendance within the specified period.',
                'details' => [
                    'current_device_id' => $attendance->device_id,
                    'period_days' => $daysPeriod,
                    'unique_devices_count' => $uniqueDevices->count(),
                    'device_ids' => $uniqueDevices->toArray()
                ]
            ];
        }

        return false;
    }

    /**
     * Validates role-based constraints for attendance.
     * This is a dispatcher method that handles different types of role constraints.
     *
     * @param Attendance $attendance The attendance record to validate
     * @param array $config The constraint configuration
     * @return bool|array Returns false if no violation, or violation details if constraint is violated
     */
    protected function validateRoleConstraint(Attendance $attendance, array $config): bool|array
    {
        // Skip validation if user info is not available
        if (empty($attendance->user_id)) {
            return false;
        }

        // Get constraint subtype
        $subtype = $config['subtype'] ?? '';

        switch ($subtype) {
            case AttendanceConstraint::ROLE_DEPARTMENT_RULES:
                return $this->validateDepartmentRules($attendance, $config);

            case AttendanceConstraint::ROLE_LEVEL_RESTRICTIONS:
                return $this->validateLevelRestrictions($attendance, $config);

            case AttendanceConstraint::ROLE_PROBATIONARY_RULES:
                return $this->validateProbationaryRules($attendance, $config);

            case AttendanceConstraint::ROLE_CONTRACT_CONSTRAINTS:
                return $this->validateContractConstraints($attendance, $config);

            case AttendanceConstraint::ROLE_SUPERVISOR_OVERRIDE:
                return $this->validateSupervisorOverride($attendance, $config);

            default:
                return false;
        }
    }

    /**
     * Validates department-specific rules for attendance.
     *
     * @param Attendance $attendance The attendance record to validate
     * @param array $config The constraint configuration
     * @return bool|array Returns false if no violation, or violation details if constraint is violated
     */
    protected function validateDepartmentRules(Attendance $attendance, array $config): bool|array
    {
        // Get user's department
        $user = app(UserRepository::class)->find($attendance->user_id);
        if (!$user || empty($user->department_id)) {
            return false;
        }

        // Get department rules from config
        $departmentRules = $config['department_rules'] ?? [];

        // Find rules for this department
        $rules = collect($departmentRules)->firstWhere('department_id', $user->department_id);
        if (!$rules) {
            return false;
        }

        // Apply department-specific time constraints
        if (isset($rules['work_hours']) && is_numeric($rules['work_hours'])) {
            // Check if the user has worked the required hours
            if ($attendance->clock_out_time) {
                $clockInTime = Carbon::parse($attendance->clock_in_time);
                $clockOutTime = Carbon::parse($attendance->clock_out_time);
                $workedMinutes = $clockInTime->diffInMinutes($clockOutTime);

                // Subtract break time if applicable
                if ($attendance->total_break_time) {
                    $workedMinutes -= $attendance->total_break_time;
                }

                $requiredMinutes = (float)$rules['work_hours'] * 60;

                if ($workedMinutes < $requiredMinutes) {
                    $shortfall = $requiredMinutes - $workedMinutes;
                    $shortfallHours = round($shortfall / 60, 2);

                    return [
                        'constraint_type' => AttendanceConstraint::ROLE_DEPARTMENT_RULES,
                        'severity' => $this->getSeverityFromConfig($config),
                        'message' => "Department work hour requirement not met. {$shortfallHours} hours short.",
                        'details' => [
                            'department_id' => $user->department_id,
                            'required_minutes' => $requiredMinutes,
                            'worked_minutes' => $workedMinutes,
                            'shortfall_minutes' => $shortfall
                        ]
                    ];
                }
            }
        }

        return false;
    }

    /**
     * Validates level-based restrictions for attendance.
     *
     * @param Attendance $attendance The attendance record to validate
     * @param array $config The constraint configuration
     * @return bool|array Returns false if no violation, or violation details if constraint is violated
     */
    protected function validateLevelRestrictions(Attendance $attendance, array $config): bool|array
    {
        // Get user's level/role
        $user = app(UserRepository::class)->find($attendance->user_id);
        if (!$user || empty($user->role_id)) {
            return false;
        }

        // Get level restrictions from config
        $levelRestrictions = $config['level_restrictions'] ?? [];

        // Find restrictions for this role level
        $restrictions = collect($levelRestrictions)->firstWhere('role_id', $user->role_id);
        if (!$restrictions) {
            return false;
        }

        // Check for flexible hours permission
        $flexibleHoursAllowed = $restrictions['flexible_hours'] ?? false;

        // If flexible hours are not allowed, check for strict time compliance
        if (!$flexibleHoursAllowed && isset($config['scheduled_start_time'])) {
            $scheduledStartTime = Carbon::parse($config['scheduled_start_time']);
            $clockInTime = Carbon::parse($attendance->clock_in_time);

            // Allow grace period (default: 5 minutes)
            $gracePeriodMinutes = $restrictions['grace_period_minutes'] ?? 5;
            $latestAllowedTime = $scheduledStartTime->copy()->addMinutes($gracePeriodMinutes);

            if ($clockInTime->gt($latestAllowedTime)) {
                $minutesLate = $clockInTime->diffInMinutes($scheduledStartTime);

                return [
                    'constraint_type' => AttendanceConstraint::ROLE_LEVEL_RESTRICTIONS,
                    'severity' => $this->getSeverityFromConfig($config),
                    'message' => "Strict time compliance required for role level. {$minutesLate} minutes late.",
                    'details' => [
                        'role_id' => $user->role_id,
                        'scheduled_time' => $scheduledStartTime->toDateTimeString(),
                        'clock_in_time' => $clockInTime->toDateTimeString(),
                        'grace_period_minutes' => $gracePeriodMinutes,
                        'minutes_late' => $minutesLate
                    ]
                ];
            }
        }

        return false;
    }

    /**
     * Validates probationary period rules for attendance.
     *
     * @param Attendance $attendance The attendance record to validate
     * @param array $config The constraint configuration
     * @return bool|array Returns false if no violation, or violation details if constraint is violated
     */
    protected function validateProbationaryRules(Attendance $attendance, array $config): bool|array
    {
        // Get user details including hire date
        $user = app(UserRepository::class)->find($attendance->user_id);
        if (!$user || empty($user->hire_date)) {
            return false;
        }

        // Get probationary period length (default: 90 days)
        $probationDays = $config['probation_days'] ?? 90;

        // Calculate if user is still in probation
        $hireDate = Carbon::parse($user->hire_date);
        $probationEndDate = $hireDate->copy()->addDays($probationDays);
        $currentDate = Carbon::parse($attendance->clock_in_time)->startOfDay();

        $isInProbation = $currentDate->lte($probationEndDate);
        if (!$isInProbation) {
            return false; // Not in probation period, no violation
        }

        // Apply stricter rules for probationary employees

        // Check for late arrival (no grace period for probationary employees)
        if (isset($config['scheduled_start_time'])) {
            $scheduledStartTime = Carbon::parse($config['scheduled_start_time']);
            $clockInTime = Carbon::parse($attendance->clock_in_time);

            if ($clockInTime->gt($scheduledStartTime)) {
                $minutesLate = $clockInTime->diffInMinutes($scheduledStartTime);

                return [
                    'constraint_type' => AttendanceConstraint::ROLE_PROBATIONARY_RULES,
                    'severity' => $this->getSeverityFromConfig($config),
                    'message' => "Probationary employee arrived late. {$minutesLate} minutes late.",
                    'details' => [
                        'hire_date' => $hireDate->toDateString(),
                        'probation_end_date' => $probationEndDate->toDateString(),
                        'days_remaining' => $currentDate->diffInDays($probationEndDate),
                        'scheduled_time' => $scheduledStartTime->toDateTimeString(),
                        'clock_in_time' => $clockInTime->toDateTimeString(),
                        'minutes_late' => $minutesLate
                    ]
                ];
            }
        }

        return false;
    }

    /**
     * Validates contract-specific constraints for attendance.
     *
     * @param Attendance $attendance The attendance record to validate
     * @param array $config The constraint configuration
     * @return bool|array Returns false if no violation, or violation details if constraint is violated
     */
    protected function validateContractConstraints(Attendance $attendance, array $config): bool|array
    {
        // Get user's contract details
        $user = app(UserRepository::class)->find($attendance->user_id);
        if (!$user || empty($user->contract_type)) {
            return false;
        }

        // Get contract constraints from config
        $contractConstraints = $config['contract_constraints'] ?? [];

        // Find constraints for this contract type
        $constraints = collect($contractConstraints)->firstWhere('contract_type', $user->contract_type);
        if (!$constraints) {
            return false;
        }

        // Check for maximum weekly hours
        if (isset($constraints['max_weekly_hours']) && is_numeric($constraints['max_weekly_hours'])) {
            // Calculate week start date (assuming week starts on Monday)
            $attendanceDate = Carbon::parse($attendance->clock_in_time);
            $weekStartDate = $attendanceDate->copy()->startOfWeek();
            $weekEndDate = $weekStartDate->copy()->endOfWeek();

            // Get total hours worked this week
            $weeklyAttendances = app(AttendanceRepository::class)->getUserAttendanceInPeriod(
                $attendance->user_id,
                $weekStartDate->toDateString(),
                $weekEndDate->toDateString()
            );

            $totalMinutesThisWeek = 0;
            foreach ($weeklyAttendances as $record) {
                if ($record->clock_in_time && $record->clock_out_time) {
                    $recordInTime = Carbon::parse($record->clock_in_time);
                    $recordOutTime = Carbon::parse($record->clock_out_time);
                    $recordMinutes = $recordInTime->diffInMinutes($recordOutTime);

                    // Subtract break time if applicable
                    if ($record->total_break_time) {
                        $recordMinutes -= $record->total_break_time;
                    }

                    $totalMinutesThisWeek += $recordMinutes;
                }
            }

            // Add current attendance if it has clock out time
            if ($attendance->clock_out_time && !$weeklyAttendances->contains('id', $attendance->id)) {
                $clockInTime = Carbon::parse($attendance->clock_in_time);
                $clockOutTime = Carbon::parse($attendance->clock_out_time);
                $currentMinutes = $clockInTime->diffInMinutes($clockOutTime);

                // Subtract break time if applicable
                if ($attendance->total_break_time) {
                    $currentMinutes -= $attendance->total_break_time;
                }

                $totalMinutesThisWeek += $currentMinutes;
            }

            // Convert to hours
            $totalHoursThisWeek = $totalMinutesThisWeek / 60;
            $maxWeeklyHours = (float)$constraints['max_weekly_hours'];

            if ($totalHoursThisWeek > $maxWeeklyHours) {
                $excessHours = round($totalHoursThisWeek - $maxWeeklyHours, 2);

                return [
                    'constraint_type' => AttendanceConstraint::ROLE_CONTRACT_CONSTRAINTS,
                    'severity' => $this->getSeverityFromConfig($config),
                    'message' => "Contract maximum weekly hours exceeded. {$excessHours} hours over limit.",
                    'details' => [
                        'contract_type' => $user->contract_type,
                        'max_weekly_hours' => $maxWeeklyHours,
                        'total_hours_worked' => round($totalHoursThisWeek, 2),
                        'excess_hours' => $excessHours,
                        'week_start_date' => $weekStartDate->toDateString(),
                        'week_end_date' => $weekEndDate->toDateString()
                    ]
                ];
            }
        }

        return false;
    }

    /**
     * Validates supervisor override constraints for attendance.
     *
     * @param Attendance $attendance The attendance record to validate
     * @param array $config The constraint configuration
     * @return bool|array Returns false if no violation, or violation details if constraint is violated
     */
    protected function validateSupervisorOverride(Attendance $attendance, array $config): bool|array
    {
        // Check if this attendance record requires supervisor approval
        $requiresApproval = false;

        // Check for late arrival requiring approval
        if (isset($config['scheduled_start_time']) && isset($config['late_threshold_minutes'])) {
            $scheduledStartTime = Carbon::parse($config['scheduled_start_time']);
            $clockInTime = Carbon::parse($attendance->clock_in_time);
            $lateThresholdMinutes = (int)$config['late_threshold_minutes'];

            if ($clockInTime->gt($scheduledStartTime->copy()->addMinutes($lateThresholdMinutes))) {
                $requiresApproval = true;
            }
        }

        // Check for early departure requiring approval
        if (isset($config['scheduled_end_time']) && isset($config['early_threshold_minutes'])) {
            $scheduledEndTime = Carbon::parse($config['scheduled_end_time']);

            if ($attendance->clock_out_time) {
                $clockOutTime = Carbon::parse($attendance->clock_out_time);
                $earlyThresholdMinutes = (int)$config['early_threshold_minutes'];

                if ($clockOutTime->lt($scheduledEndTime->copy()->subMinutes($earlyThresholdMinutes))) {
                    $requiresApproval = true;
                }
            }
        }

        // If approval is required, check if it was granted
        if ($requiresApproval) {
            $supervisorApproved = $attendance->supervisor_approved ?? false;

            if (!$supervisorApproved) {
                return [
                    'constraint_type' => AttendanceConstraint::ROLE_SUPERVISOR_OVERRIDE,
                    'severity' => $this->getSeverityFromConfig($config),
                    'message' => 'Attendance exception requires supervisor approval.',
                    'details' => [
                        'attendance_id' => $attendance->id,
                        'user_id' => $attendance->user_id,
                        'clock_in_time' => $attendance->clock_in_time,
                        'clock_out_time' => $attendance->clock_out_time,
                        'requires_approval_reason' => 'Time exception outside of allowed thresholds'
                    ]
                ];
            }
        }

        return false;
    }

    /**
     * Validates behavioral constraints for attendance.
     * This is a dispatcher method that handles different types of behavioral constraints.
     *
     * @param Attendance $attendance The attendance record to validate
     * @param array $config The constraint configuration
     * @return bool|array Returns false if no violation, or violation details if constraint is violated
     */
    protected function validateBehavioralConstraint(Attendance $attendance, array $config): bool|array
    {
        // Skip validation if user info is not available
        if (empty($attendance->user_id)) {
            return false;
        }

        // Get constraint subtype
        $subtype = $config['subtype'] ?? '';

        switch ($subtype) {
            case AttendanceConstraint::BEHAVIORAL_CONSECUTIVE_LIMIT:
                return $this->validateConsecutiveLimit($attendance, $config);

            case AttendanceConstraint::BEHAVIORAL_WEEKLY_HOURS:
                return $this->validateWeeklyHours($attendance, $config);

            case AttendanceConstraint::BEHAVIORAL_REST_PERIODS:
                return $this->validateRestPeriods($attendance, $config);

            case AttendanceConstraint::BEHAVIORAL_HOLIDAY_WORK:
                return $this->validateHolidayWork($attendance, $config);

            case AttendanceConstraint::BEHAVIORAL_PATTERN_MONITORING:
                return $this->validatePatternMonitoring($attendance, $config);

            default:
                return false;
        }
    }

    /**
     * Validates consecutive work days limit.
     *
     * @param Attendance $attendance The attendance record to validate
     * @param array $config The constraint configuration
     * @return bool|array Returns false if no violation, or violation details if constraint is violated
     */
    protected function validateConsecutiveLimit(Attendance $attendance, array $config): bool|array
    {
        // Get maximum consecutive days allowed (default: 6 days)
        $maxConsecutiveDays = $config['max_consecutive_days'] ?? 6;

        // Get current date from attendance
        $currentDate = Carbon::parse($attendance->clock_in_time)->startOfDay();

        // Look back for consecutive days worked
        $consecutiveDays = 1; // Start with current day
        $checkDate = $currentDate->copy();

        for ($i = 1; $i <= $maxConsecutiveDays; $i++) {
            $checkDate = $checkDate->subDay();

            // Check if user worked on this day
            $hasAttendance = app(AttendanceRepository::class)->userWorkedOnDate(
                $attendance->user_id,
                $checkDate->toDateString()
            );

            if ($hasAttendance) {
                $consecutiveDays++;
            } else {
                break; // Break the streak
            }
        }

        if ($consecutiveDays > $maxConsecutiveDays) {
            return [
                'constraint_type' => AttendanceConstraint::BEHAVIORAL_CONSECUTIVE_LIMIT,
                'severity' => $this->getSeverityFromConfig($config),
                'message' => "Maximum consecutive work days exceeded. Worked {$consecutiveDays} days without a break.",
                'details' => [
                    'max_consecutive_days' => $maxConsecutiveDays,
                    'actual_consecutive_days' => $consecutiveDays,
                    'first_day' => $checkDate->addDay()->toDateString(), // Add one day back to get first day of streak
                    'current_day' => $currentDate->toDateString()
                ]
            ];
        }

        return false;
    }

    /**
     * Validates weekly work hours limit.
     *
     * @param Attendance $attendance The attendance record to validate
     * @param array $config The constraint configuration
     * @return bool|array Returns false if no violation, or violation details if constraint is violated
     */
    protected function validateWeeklyHours(Attendance $attendance, array $config): bool|array
    {
        // Get maximum weekly hours allowed (default: 48 hours)
        $maxWeeklyHours = $config['max_weekly_hours'] ?? 48;

        // Calculate week start and end dates
        $attendanceDate = Carbon::parse($attendance->clock_in_time);
        $weekStartDate = $attendanceDate->copy()->startOfWeek();
        $weekEndDate = $weekStartDate->copy()->endOfWeek();

        // Get all attendance records for this week
        $weeklyAttendances = app(AttendanceRepository::class)->getUserAttendanceInPeriod(
            $attendance->user_id,
            $weekStartDate->toDateString(),
            $weekEndDate->toDateString()
        );

        // Calculate total hours worked this week
        $totalMinutesThisWeek = 0;
        foreach ($weeklyAttendances as $record) {
            if ($record->clock_in_time && $record->clock_out_time) {
                $recordInTime = Carbon::parse($record->clock_in_time);
                $recordOutTime = Carbon::parse($record->clock_out_time);
                $recordMinutes = $recordInTime->diffInMinutes($recordOutTime);

                // Subtract break time if applicable
                if ($record->total_break_time) {
                    $recordMinutes -= $record->total_break_time;
                }

                $totalMinutesThisWeek += $recordMinutes;
            }
        }

        // Add current attendance if it has clock out time and is not already counted
        if ($attendance->clock_out_time && !$weeklyAttendances->contains('id', $attendance->id)) {
            $clockInTime = Carbon::parse($attendance->clock_in_time);
            $clockOutTime = Carbon::parse($attendance->clock_out_time);
            $currentMinutes = $clockInTime->diffInMinutes($clockOutTime);

            // Subtract break time if applicable
            if ($attendance->total_break_time) {
                $currentMinutes -= $attendance->total_break_time;
            }

            $totalMinutesThisWeek += $currentMinutes;
        }

        // Convert to hours
        $totalHoursThisWeek = $totalMinutesThisWeek / 60;

        if ($totalHoursThisWeek > $maxWeeklyHours) {
            $excessHours = round($totalHoursThisWeek - $maxWeeklyHours, 2);

            return [
                'constraint_type' => AttendanceConstraint::BEHAVIORAL_WEEKLY_HOURS,
                'severity' => $this->getSeverityFromConfig($config),
                'message' => "Weekly work hour limit exceeded. {$excessHours} hours over limit.",
                'details' => [
                    'max_weekly_hours' => $maxWeeklyHours,
                    'total_hours_worked' => round($totalHoursThisWeek, 2),
                    'excess_hours' => $excessHours,
                    'week_start_date' => $weekStartDate->toDateString(),
                    'week_end_date' => $weekEndDate->toDateString()
                ]
            ];
        }

        return false;
    }

    /**
     * Validates required rest periods between shifts.
     *
     * @param Attendance $attendance The attendance record to validate
     * @param array $config The constraint configuration
     * @return bool|array Returns false if no violation, or violation details if constraint is violated
     */
    protected function validateRestPeriods(Attendance $attendance, array $config): bool|array
    {
        // Get minimum rest hours required between shifts (default: 11 hours)
        $minRestHours = $config['min_rest_hours'] ?? 11;

        // Get current clock-in time
        $currentClockIn = Carbon::parse($attendance->clock_in_time);

        // Get previous attendance record with clock-out time
        $previousAttendance = app(AttendanceRepository::class)->getPreviousAttendanceWithClockOut(
            $attendance->user_id,
            $currentClockIn->toDateTimeString()
        );

        if (!$previousAttendance || empty($previousAttendance->clock_out_time)) {
            return false; // No previous attendance to compare with
        }

        // Calculate rest period between previous clock-out and current clock-in
        $previousClockOut = Carbon::parse($previousAttendance->clock_out_time);
        $restMinutes = $previousClockOut->diffInMinutes($currentClockIn);
        $restHours = $restMinutes / 60;

        if ($restHours < $minRestHours) {
            $shortfallHours = round($minRestHours - $restHours, 2);

            return [
                'constraint_type' => AttendanceConstraint::BEHAVIORAL_REST_PERIODS,
                'severity' => $this->getSeverityFromConfig($config),
                'message' => "Insufficient rest period between shifts. {$shortfallHours} hours short of required rest.",
                'details' => [
                    'min_rest_hours' => $minRestHours,
                    'actual_rest_hours' => round($restHours, 2),
                    'shortfall_hours' => $shortfallHours,
                    'previous_clock_out' => $previousClockOut->toDateTimeString(),
                    'current_clock_in' => $currentClockIn->toDateTimeString()
                ]
            ];
        }

        return false;
    }

    /**
     * Validates holiday work constraints.
     *
     * @param Attendance $attendance The attendance record to validate
     * @param array $config The constraint configuration
     * @return bool|array Returns false if no violation, or violation details if constraint is violated
     */
    protected function validateHolidayWork(Attendance $attendance, array $config): bool|array
    {
        // Get current date from attendance
        $attendanceDate = Carbon::parse($attendance->clock_in_time)->startOfDay();

        // Check if this date is a holiday
        $isHoliday = app(HolidayRepository::class)->isHoliday(
            $attendanceDate->toDateString(),
            $attendance->company_id ?? null
        );

        if (!$isHoliday) {
            return false; // Not a holiday, no violation
        }

        // Check if holiday work is allowed
        $holidayWorkAllowed = $config['holiday_work_allowed'] ?? false;

        if (!$holidayWorkAllowed) {
            return [
                'constraint_type' => AttendanceConstraint::BEHAVIORAL_HOLIDAY_WORK,
                'severity' => $this->getSeverityFromConfig($config),
                'message' => 'Work on holidays is not allowed.',
                'details' => [
                    'date' => $attendanceDate->toDateString(),
                    'clock_in_time' => $attendance->clock_in_time,
                    'holiday_work_allowed' => false
                ]
            ];
        }

        // Check if holiday work requires approval
        $requiresApproval = $config['requires_approval'] ?? true;

        if ($requiresApproval) {
            $holidayApproved = $attendance->holiday_approved ?? false;

            if (!$holidayApproved) {
                return [
                    'constraint_type' => AttendanceConstraint::BEHAVIORAL_HOLIDAY_WORK,
                    'severity' => $this->getSeverityFromConfig($config),
                    'message' => 'Holiday work requires approval.',
                    'details' => [
                        'date' => $attendanceDate->toDateString(),
                        'clock_in_time' => $attendance->clock_in_time,
                        'holiday_work_allowed' => true,
                        'requires_approval' => true,
                        'is_approved' => false
                    ]
                ];
            }
        }

        return false;
    }

    /**
     * Validates attendance patterns for suspicious behavior.
     *
     * @param Attendance $attendance The attendance record to validate
     * @param array $config The constraint configuration
     * @return bool|array Returns false if no violation, or violation details if constraint is violated
     */
    protected function validatePatternMonitoring(Attendance $attendance, array $config): bool|array
    {
        // Get monitoring period in days (default: 30 days)
        $monitoringPeriod = $config['monitoring_period_days'] ?? 30;

        // Get current date from attendance
        $currentDate = Carbon::parse($attendance->clock_in_time);
        $startDate = $currentDate->copy()->subDays($monitoringPeriod)->startOfDay();

        // Get all attendance records for this period
        $periodAttendances = app(AttendanceRepository::class)->getUserAttendanceInPeriod(
            $attendance->user_id,
            $startDate->toDateString(),
            $currentDate->toDateString()
        );

        // Skip if not enough data
        if ($periodAttendances->count() < 5) {
            return false;
        }

        // Check for suspicious patterns
        $suspiciousPatterns = [];

        // Pattern 1: Exact same clock-in time (to the minute) for multiple days
        $clockInTimes = $periodAttendances->pluck('clock_in_time')->map(function ($time) {
            return Carbon::parse($time)->format('H:i');
        });

        $clockInCounts = $clockInTimes->countBy();
        $exactTimeThreshold = $config['exact_time_threshold'] ?? 5;

        foreach ($clockInCounts as $time => $count) {
            if ($count >= $exactTimeThreshold) {
                $suspiciousPatterns[] = [
                    'type' => 'exact_clock_in_time',
                    'details' => "Exact same clock-in time ({$time}) on {$count} different days"
                ];
            }
        }

        // Pattern 2: Always clocking out exactly at end of shift
        if (!empty($config['scheduled_end_time'])) {
            $scheduledEndTime = Carbon::parse($config['scheduled_end_time'])->format('H:i');
            $exactEndTimeCount = 0;

            foreach ($periodAttendances as $record) {
                if ($record->clock_out_time) {
                    $clockOutTime = Carbon::parse($record->clock_out_time)->format('H:i');
                    if ($clockOutTime === $scheduledEndTime) {
                        $exactEndTimeCount++;
                    }
                }
            }

            $exactEndTimeThreshold = $config['exact_end_time_threshold'] ?? 5;
            if ($exactEndTimeCount >= $exactEndTimeThreshold) {
                $suspiciousPatterns[] = [
                    'type' => 'exact_clock_out_time',
                    'details' => "Exact scheduled end time ({$scheduledEndTime}) on {$exactEndTimeCount} different days"
                ];
            }
        }

        // If suspicious patterns found, report violation
        if (!empty($suspiciousPatterns)) {
            return [
                'constraint_type' => AttendanceConstraint::BEHAVIORAL_PATTERN_MONITORING,
                'severity' => $this->getSeverityFromConfig($config),
                'message' => 'Suspicious attendance patterns detected.',
                'details' => [
                    'monitoring_period_days' => $monitoringPeriod,
                    'records_analyzed' => $periodAttendances->count(),
                    'suspicious_patterns' => $suspiciousPatterns
                ]
            ];
        }

        return false;
    }

    /**
     * Validates security constraints for attendance.
     * This is a dispatcher method that handles different types of security constraints.
     *
     * @param Attendance $attendance The attendance record to validate
     * @param array $config The constraint configuration
     * @return bool|array Returns false if no violation, or violation details if constraint is violated
     */
    protected function validateSecurityConstraint(Attendance $attendance, array $config): bool|array
    {
        // Get constraint subtype
        $subtype = $config['subtype'] ?? '';

        switch ($subtype) {
            case AttendanceConstraint::SECURITY_TWO_FACTOR:
                return $this->validateTwoFactorAuth($attendance, $config);

            case AttendanceConstraint::SECURITY_BIOMETRIC:
                return $this->validateBiometricAuth($attendance, $config);

            case AttendanceConstraint::SECURITY_AUDIT_TRAIL:
                return $this->validateAuditTrail($attendance, $config);

            case AttendanceConstraint::SECURITY_FRAUD_DETECTION:
                return $this->validateFraudDetection($attendance, $config);

            case AttendanceConstraint::SECURITY_DATA_ENCRYPTION:
                return $this->validateDataEncryption($attendance, $config);

            default:
                return false;
        }
    }

    /**
     * Validates two-factor authentication requirement.
     *
     * @param Attendance $attendance The attendance record to validate
     * @param array $config The constraint configuration
     * @return bool|array Returns false if no violation, or violation details if constraint is violated
     */
    protected function validateTwoFactorAuth(Attendance $attendance, array $config): bool|array
    {
        // Check if two-factor authentication is required
        $twoFactorRequired = $config['two_factor_required'] ?? false;

        if (!$twoFactorRequired) {
            return false;
        }

        // Check if two-factor was used for this attendance
        $twoFactorUsed = $attendance->two_factor_verified ?? false;

        if (!$twoFactorUsed) {
            return [
                'constraint_type' => AttendanceConstraint::SECURITY_TWO_FACTOR,
                'severity' => $this->getSeverityFromConfig($config),
                'message' => 'Two-factor authentication required but not used.',
                'details' => [
                    'attendance_id' => $attendance->id,
                    'user_id' => $attendance->user_id,
                    'clock_in_time' => $attendance->clock_in_time,
                    'two_factor_required' => true,
                    'two_factor_used' => false
                ]
            ];
        }

        return false;
    }

    /**
     * Validates biometric authentication requirement.
     *
     * @param Attendance $attendance The attendance record to validate
     * @param array $config The constraint configuration
     * @return bool|array Returns false if no violation, or violation details if constraint is violated
     */
    protected function validateBiometricAuth(Attendance $attendance, array $config): bool|array
    {
        // Check if biometric authentication is required
        $biometricRequired = $config['biometric_required'] ?? false;

        if (!$biometricRequired) {
            return false;
        }

        // Check if biometric was used for this attendance
        $biometricUsed = $attendance->biometric_verified ?? false;

        if (!$biometricUsed) {
            return [
                'constraint_type' => AttendanceConstraint::SECURITY_BIOMETRIC,
                'severity' => $this->getSeverityFromConfig($config),
                'message' => 'Biometric authentication required but not used.',
                'details' => [
                    'attendance_id' => $attendance->id,
                    'user_id' => $attendance->user_id,
                    'clock_in_time' => $attendance->clock_in_time,
                    'biometric_required' => true,
                    'biometric_used' => false
                ]
            ];
        }

        return false;
    }

    /**
     * Validates audit trail requirement.
     *
     * @param Attendance $attendance The attendance record to validate
     * @param array $config The constraint configuration
     * @return bool|array Returns false if no violation, or violation details if constraint is violated
     */
    protected function validateAuditTrail(Attendance $attendance, array $config): bool|array
    {
        // Check if audit trail information is required
        $auditTrailRequired = $config['audit_trail_required'] ?? false;

        if (!$auditTrailRequired) {
            return false;
        }

        // Check if required audit fields are present
        $requiredFields = $config['required_fields'] ?? ['ip_address', 'device_info', 'location_data'];
        $missingFields = [];

        foreach ($requiredFields as $field) {
            if (empty($attendance->$field)) {
                $missingFields[] = $field;
            }
        }

        if (!empty($missingFields)) {
            return [
                'constraint_type' => AttendanceConstraint::SECURITY_AUDIT_TRAIL,
                'severity' => $this->getSeverityFromConfig($config),
                'message' => 'Required audit trail information missing.',
                'details' => [
                    'attendance_id' => $attendance->id,
                    'user_id' => $attendance->user_id,
                    'required_fields' => $requiredFields,
                    'missing_fields' => $missingFields
                ]
            ];
        }

        return false;
    }

    /**
     * Validates for potential fraud in attendance.
     *
     * @param Attendance $attendance The attendance record to validate
     * @param array $config The constraint configuration
     * @return bool|array Returns false if no violation, or violation details if constraint is violated
     */
    protected function validateFraudDetection(Attendance $attendance, array $config): bool|array
    {
        // Initialize fraud indicators
        $fraudIndicators = [];

        // Check for impossible travel speed if location data is available
        if (!empty($attendance->location_data) && isset($config['check_travel_speed']) && $config['check_travel_speed']) {
            // Get previous attendance record with location data
            $previousAttendance = app(AttendanceRepository::class)->getPreviousAttendanceWithLocation(
                $attendance->user_id,
                $attendance->clock_in_time
            );

            if ($previousAttendance && !empty($previousAttendance->location_data)) {
                // Calculate time difference in hours
                $prevTime = Carbon::parse($previousAttendance->clock_out_time ?? $previousAttendance->clock_in_time);
                $currentTime = Carbon::parse($attendance->clock_in_time);
                $hoursDiff = $prevTime->diffInMinutes($currentTime) / 60;

                // Skip if records are too far apart in time (e.g., more than 24 hours)
                if ($hoursDiff < 24) {
                    // Calculate distance between locations
                    $prevLat = $previousAttendance->location_data['latitude'] ?? 0;
                    $prevLng = $previousAttendance->location_data['longitude'] ?? 0;
                    $currLat = $attendance->location_data['latitude'] ?? 0;
                    $currLng = $attendance->location_data['longitude'] ?? 0;

                    $distanceKm = $this->calculateDistance($prevLat, $prevLng, $currLat, $currLng);

                    // Calculate required travel speed in km/h
                    $speedRequired = ($hoursDiff > 0) ? ($distanceKm / $hoursDiff) : 1000;

                    // Flag if speed is unrealistic (e.g., > 500 km/h)
                    $maxSpeed = $config['max_travel_speed_kmh'] ?? 500;
                    if ($speedRequired > $maxSpeed) {
                        $fraudIndicators[] = [
                            'type' => 'impossible_travel',
                            'details' => "Impossible travel speed detected: {$speedRequired} km/h over {$distanceKm} km"
                        ];
                    }
                }
            }
        }

        // Check for multiple clock-ins from different locations in short time
        if (isset($config['check_multiple_locations']) && $config['check_multiple_locations']) {
            // Implementation would check for multiple clock-ins from different locations
            // within a short time period (e.g., same day)
        }

        // Check for pattern of clock-ins just after shift start and clock-outs just before shift end
        if (isset($config['check_suspicious_patterns']) && $config['check_suspicious_patterns']) {
            // Implementation would analyze patterns over time
        }

        // If fraud indicators found, report violation
        if (!empty($fraudIndicators)) {
            return [
                'constraint_type' => AttendanceConstraint::SECURITY_FRAUD_DETECTION,
                'severity' => $this->getSeverityFromConfig($config),
                'message' => 'Potential attendance fraud detected.',
                'details' => [
                    'attendance_id' => $attendance->id,
                    'user_id' => $attendance->user_id,
                    'fraud_indicators' => $fraudIndicators
                ]
            ];
        }

        return false;
    }

    /**
     * Validates data encryption requirements.
     *
     * @param Attendance $attendance The attendance record to validate
     * @param array $config The constraint configuration
     * @return bool|array Returns false if no violation, or violation details if constraint is violated
     */
    protected function validateDataEncryption(Attendance $attendance, array $config): bool|array
    {
        // Check if encryption is required
        $encryptionRequired = $config['encryption_required'] ?? false;

        if (!$encryptionRequired) {
            return false;
        }

        // Check if sensitive data is encrypted
        // This would typically be handled at the database/model level
        // Here we're just checking if the encryption flag is set
        $isEncrypted = $attendance->is_encrypted ?? false;

        if (!$isEncrypted) {
            return [
                'constraint_type' => AttendanceConstraint::SECURITY_DATA_ENCRYPTION,
                'severity' => $this->getSeverityFromConfig($config),
                'message' => 'Required data encryption not applied.',
                'details' => [
                    'attendance_id' => $attendance->id,
                    'encryption_required' => true,
                    'is_encrypted' => false
                ]
            ];
        }

        return false;
    }

    /**
     * Validates compliance constraints for attendance.
     * This is a dispatcher method that handles different types of compliance constraints.
     *
     * @param Attendance $attendance The attendance record to validate
     * @param array $config The constraint configuration
     * @return bool|array Returns false if no violation, or violation details if constraint is violated
     */
    protected function validateComplianceConstraint(Attendance $attendance, array $config): bool|array
    {
        // Get constraint subtype
        $subtype = $config['subtype'] ?? '';

        switch ($subtype) {
            case AttendanceConstraint::COMPLIANCE_LABOR_LAW:
                return $this->validateLaborLaw($attendance, $config);

            case AttendanceConstraint::COMPLIANCE_UNION_AGREEMENT:
                return $this->validateUnionAgreement($attendance, $config);

            case AttendanceConstraint::COMPLIANCE_INDUSTRY_RULES:
                return $this->validateIndustryRules($attendance, $config);

            case AttendanceConstraint::COMPLIANCE_GOVERNMENT_REPORTING:
                return $this->validateGovernmentReporting($attendance, $config);

            case AttendanceConstraint::COMPLIANCE_DOCUMENTATION:
                return $this->validateDocumentation($attendance, $config);

            case AttendanceConstraint::COMPLIANCE_OFFICE_VERIFICATION:
                return $this->validateOfficeVerification($attendance, $config);

            default:
                return false;
        }
    }

    /**
     * Validates labor law compliance.
     *
     * @param Attendance $attendance The attendance record to validate
     * @param array $config The constraint configuration
     * @return bool|array Returns false if no violation, or violation details if constraint is violated
     */
    protected function validateLaborLaw(Attendance $attendance, array $config): bool|array
    {
        // Skip if no clock out time (can't calculate total work time)
        if (!$attendance->clock_out_time) {
            return false;
        }

        // Get country/region code for applicable labor laws
        $countryCode = $config['country_code'] ?? 'default';

        // Get labor law limits based on country/region
        $laborLaws = $config['labor_laws'] ?? [];
        $applicableLaw = $laborLaws[$countryCode] ?? $laborLaws['default'] ?? null;

        if (!$applicableLaw) {
            return false;
        }

        // Calculate total work time
        $clockInTime = Carbon::parse($attendance->clock_in_time);
        $clockOutTime = Carbon::parse($attendance->clock_out_time);
        $totalWorkMinutes = $clockInTime->diffInMinutes($clockOutTime);

        // Subtract break time if applicable
        if ($attendance->total_break_time) {
            $totalWorkMinutes -= $attendance->total_break_time;
        }

        $totalWorkHours = $totalWorkMinutes / 60;

        // Check maximum daily hours
        $maxDailyHours = $applicableLaw['max_daily_hours'] ?? 12;
        if ($totalWorkHours > $maxDailyHours) {
            $excessHours = round($totalWorkHours - $maxDailyHours, 2);

            return [
                'constraint_type' => AttendanceConstraint::COMPLIANCE_LABOR_LAW,
                'severity' => $this->getSeverityFromConfig($config),
                'message' => "Labor law violation: Maximum daily work hours exceeded by {$excessHours} hours.",
                'details' => [
                    'country_code' => $countryCode,
                    'max_daily_hours' => $maxDailyHours,
                    'actual_hours' => round($totalWorkHours, 2),
                    'excess_hours' => $excessHours
                ]
            ];
        }

        // Check required breaks
        $requiredBreakMinutes = $applicableLaw['required_break_minutes'] ?? 0;
        $workThresholdForBreak = $applicableLaw['work_threshold_for_break'] ?? 6;

        if ($totalWorkHours >= $workThresholdForBreak &&
            ($attendance->total_break_time ?? 0) < $requiredBreakMinutes) {

            $missingBreakMinutes = $requiredBreakMinutes - ($attendance->total_break_time ?? 0);

            return [
                'constraint_type' => AttendanceConstraint::COMPLIANCE_LABOR_LAW,
                'severity' => $this->getSeverityFromConfig($config),
                'message' => "Labor law violation: Required break time not met. {$missingBreakMinutes} minutes short.",
                'details' => [
                    'country_code' => $countryCode,
                    'required_break_minutes' => $requiredBreakMinutes,
                    'actual_break_minutes' => $attendance->total_break_time ?? 0,
                    'missing_break_minutes' => $missingBreakMinutes
                ]
            ];
        }

        return false;
    }

    /**
     * Validates union agreement compliance.
     *
     * @param Attendance $attendance The attendance record to validate
     * @param array $config The constraint configuration
     * @return bool|array Returns false if no violation, or violation details if constraint is violated
     */
    protected function validateUnionAgreement(Attendance $attendance, array $config): bool|array
    {
        // Skip if no union agreement is configured
        $unionAgreements = $config['union_agreements'] ?? [];
        if (empty($unionAgreements)) {
            return false;
        }

        // Get user's union membership information
        $user = app(UserRepository::class)->find($attendance->user_id);
        if (!$user) {
            return false;
        }

        // Get user's union code if available
        $userUnionCode = $user->union_code ?? null;
        if (!$userUnionCode || !isset($unionAgreements[$userUnionCode])) {
            return false;
        }

        $agreement = $unionAgreements[$userUnionCode];
        $violations = [];

        // Check if clock-in time is within allowed hours
        if (isset($agreement['allowed_clock_in_times'])) {
            $clockInTime = Carbon::parse($attendance->clock_in_time)->format('H:i');
            $allowedTimes = $agreement['allowed_clock_in_times'];
            $isAllowed = false;

            foreach ($allowedTimes as $timeRange) {
                $start = $timeRange['start'] ?? '00:00';
                $end = $timeRange['end'] ?? '23:59';

                if ($this->isTimeWithinRange($clockInTime, $start, $end)) {
                    $isAllowed = true;
                    break;
                }
            }

            if (!$isAllowed) {
                $violations[] = [
                    'type' => 'disallowed_clock_in_time',
                    'message' => "Clock-in time {$clockInTime} is outside allowed union agreement times."
                ];
            }
        }

        // Check minimum pay requirements
        if (isset($agreement['minimum_pay_rate']) && isset($attendance->pay_rate) &&
            $attendance->pay_rate < $agreement['minimum_pay_rate']) {

            $violations[] = [
                'type' => 'below_minimum_pay_rate',
                'message' => "Pay rate below union minimum of {$agreement['minimum_pay_rate']}."
            ];
        }

        // Check overtime pay multiplier
        if (isset($agreement['overtime_multiplier']) && isset($attendance->overtime_hours) &&
            $attendance->overtime_hours > 0) {

            $requiredMultiplier = $agreement['overtime_multiplier'];
            $actualMultiplier = ($attendance->overtime_rate ?? 0) / ($attendance->regular_rate ?? 1);

            if ($actualMultiplier < $requiredMultiplier) {
                $violations[] = [
                    'type' => 'incorrect_overtime_multiplier',
                    'message' => "Overtime multiplier {$actualMultiplier}x below required {$requiredMultiplier}x."
                ];
            }
        }

        // Return violations if any found
        if (!empty($violations)) {
            return [
                'constraint_type' => AttendanceConstraint::COMPLIANCE_UNION_AGREEMENT,
                'severity' => $this->getSeverityFromConfig($config),
                'message' => 'Union agreement violations detected.',
                'details' => [
                    'union_code' => $userUnionCode,
                    'violations' => $violations
                ]
            ];
        }

        return false;
    }

    /**
     * Validates industry-specific rules compliance.
     *
     * @param Attendance $attendance The attendance record to validate
     * @param array $config The constraint configuration
     * @return bool|array Returns false if no violation, or violation details if constraint is violated
     */
    protected function validateIndustryRules(Attendance $attendance, array $config): bool|array
    {
        // Get industry code
        $industryCode = $config['industry_code'] ?? null;
        if (!$industryCode) {
            return false;
        }

        // Get industry-specific rules
        $industryRules = $config['industry_rules'] ?? [];
        if (empty($industryRules)) {
            return false;
        }

        $violations = [];

        // Check for required certifications
        if (isset($industryRules['required_certifications'])) {
            $requiredCerts = $industryRules['required_certifications'];
            $user = app(UserRepository::class)->find($attendance->user_id);

            if ($user) {
                $userCerts = $user->certifications ?? [];
                $missingCerts = [];

                foreach ($requiredCerts as $cert) {
                    $found = false;
                    foreach ($userCerts as $userCert) {
                        if ($userCert['name'] == $cert &&
                            (!isset($userCert['expiry_date']) ||
                             Carbon::parse($userCert['expiry_date'])->isFuture())) {
                            $found = true;
                            break;
                        }
                    }

                    if (!$found) {
                        $missingCerts[] = $cert;
                    }
                }

                if (!empty($missingCerts)) {
                    $violations[] = [
                        'type' => 'missing_certifications',
                        'message' => 'Required industry certifications missing or expired.',
                        'missing_certifications' => $missingCerts
                    ];
                }
            }
        }

        // Check for required rest periods between shifts (industry specific)
        if (isset($industryRules['minimum_rest_hours']) && $industryRules['minimum_rest_hours'] > 0) {
            $minRestHours = $industryRules['minimum_rest_hours'];

            // Get previous attendance record
            $previousAttendance = app(AttendanceRepository::class)->getPreviousAttendanceWithClockOut(
                $attendance->user_id,
                $attendance->clock_in_time
            );

            if ($previousAttendance && $previousAttendance->clock_out_time) {
                $prevClockOut = Carbon::parse($previousAttendance->clock_out_time);
                $currentClockIn = Carbon::parse($attendance->clock_in_time);

                $restHours = $prevClockOut->diffInMinutes($currentClockIn) / 60;

                if ($restHours < $minRestHours) {
                    $violations[] = [
                        'type' => 'insufficient_rest_period',
                        'message' => "Industry requires {$minRestHours}h rest between shifts. Only had {$restHours}h.",
                        'required_hours' => $minRestHours,
                        'actual_hours' => round($restHours, 2)
                    ];
                }
            }
        }

        // Return violations if any found
        if (!empty($violations)) {
            return [
                'constraint_type' => AttendanceConstraint::COMPLIANCE_INDUSTRY_RULES,
                'severity' => $this->getSeverityFromConfig($config),
                'message' => 'Industry-specific rule violations detected.',
                'details' => [
                    'industry_code' => $industryCode,
                    'violations' => $violations
                ]
            ];
        }

        return false;
    }

    /**
     * Validates government reporting requirements.
     *
     * @param Attendance $attendance The attendance record to validate
     * @param array $config The constraint configuration
     * @return bool|array Returns false if no violation, or violation details if constraint is violated
     */
    protected function validateGovernmentReporting(Attendance $attendance, array $config): bool|array
    {
        // Check if government reporting is required
        $reportingRequired = $config['reporting_required'] ?? false;
        if (!$reportingRequired) {
            return false;
        }

        $violations = [];

        // Check for required fields for government reporting
        $requiredFields = $config['required_fields'] ?? [];
        $missingFields = [];

        foreach ($requiredFields as $field) {
            if (empty($attendance->$field)) {
                $missingFields[] = $field;
            }
        }

        if (!empty($missingFields)) {
            $violations[] = [
                'type' => 'missing_required_fields',
                'message' => 'Required fields for government reporting are missing.',
                'missing_fields' => $missingFields
            ];
        }

        // Check for tax code validation
        if (isset($config['validate_tax_codes']) && $config['validate_tax_codes']) {
            $user = app(UserRepository::class)->find($attendance->user_id);

            if ($user && empty($user->tax_id)) {
                $violations[] = [
                    'type' => 'missing_tax_id',
                    'message' => 'Tax ID required for government reporting is missing.'
                ];
            }
        }

        // Return violations if any found
        if (!empty($violations)) {
            return [
                'constraint_type' => AttendanceConstraint::COMPLIANCE_GOVERNMENT_REPORTING,
                'severity' => $this->getSeverityFromConfig($config),
                'message' => 'Government reporting requirement violations detected.',
                'details' => [
                    'violations' => $violations
                ]
            ];
        }

        return false;
    }

    /**
     * Validates documentation requirements.
     *
     * @param Attendance $attendance The attendance record to validate
     * @param array $config The constraint configuration
     * @return bool|array Returns false if no violation, or violation details if constraint is violated
     */
    protected function validateDocumentation(Attendance $attendance, array $config): bool|array
    {
        // Check if documentation is required
        $documentationRequired = $config['documentation_required'] ?? false;
        if (!$documentationRequired) {
            return false;
        }

        $violations = [];

        // Check for required documentation types
        $requiredDocTypes = $config['required_document_types'] ?? [];
        if (!empty($requiredDocTypes)) {
            // Get attendance documentation
            $attendanceDocs = $attendance->documents ?? [];
            $missingDocTypes = [];

            foreach ($requiredDocTypes as $docType) {
                $found = false;
                foreach ($attendanceDocs as $doc) {
                    if (($doc['type'] ?? '') === $docType) {
                        $found = true;
                        break;
                    }
                }

                if (!$found) {
                    $missingDocTypes[] = $docType;
                }
            }

            if (!empty($missingDocTypes)) {
                $violations[] = [
                    'type' => 'missing_documentation',
                    'message' => 'Required documentation types are missing.',
                    'missing_types' => $missingDocTypes
                ];
            }
        }

        // Check for required notes
        if (isset($config['requires_notes']) && $config['requires_notes'] && empty($attendance->notes)) {
            $violations[] = [
                'type' => 'missing_notes',
                'message' => 'Notes are required for this attendance record.'
            ];
        }

        // Check for approval documentation
        if (isset($config['requires_approval_documentation']) && $config['requires_approval_documentation']) {
            // Check if this attendance has special circumstances that require approval
            $needsApproval = false;

            // Check for overtime
            if (isset($attendance->overtime_minutes) && $attendance->overtime_minutes > 0) {
                $needsApproval = true;
            }

            // Check for holiday work
            $holidayRepo = app(HolidayRepository::class);
            $isHoliday = $holidayRepo->isHoliday(
                Carbon::parse($attendance->clock_in_time)->toDateString(),
                $attendance->company_id ?? null
            );

            if ($isHoliday) {
                $needsApproval = true;
            }

            // If approval needed, check for approval documentation
            if ($needsApproval) {
                $hasApprovalDoc = false;

                foreach ($attendance->documents ?? [] as $doc) {
                    if (($doc['type'] ?? '') === 'approval') {
                        $hasApprovalDoc = true;
                        break;
                    }
                }

                if (!$hasApprovalDoc) {
                    $violations[] = [
                        'type' => 'missing_approval_documentation',
                        'message' => 'Approval documentation required for overtime or holiday work.'
                    ];
                }
            }
        }

        // Return violations if any found
        if (!empty($violations)) {
            return [
                'constraint_type' => AttendanceConstraint::COMPLIANCE_DOCUMENTATION,
                'severity' => $this->getSeverityFromConfig($config),
                'message' => 'Documentation requirement violations detected.',
                'details' => [
                    'violations' => $violations
                ]
            ];
        }

        return false;
    }

    /**
     * Validates office verification requirements for attendance records.
     * Ensures that attendance records have been properly verified by office administration when required.
     *
     * @param Attendance $attendance The attendance record to validate
     * @param array $config The constraint configuration
     * @return bool|array Returns false if no violation, or violation details if constraint is violated
     */
    protected function validateOfficeVerification(Attendance $attendance, array $config): bool|array
    {
        // Check if office verification is required
        $verificationRequired = $config['verification_required'] ?? false;
        if (!$verificationRequired) {
            return false;
        }

        // Check if verification has been completed
        $isVerified = $attendance->office_verified ?? false;
        if ($isVerified) {
            return false; // No violation if verified
        }

        // Check for verification deadline if specified
        if (isset($config['verification_deadline_hours'])) {
            $deadlineHours = (int)$config['verification_deadline_hours'];
            $clockOutTime = Carbon::parse($attendance->clock_out_time);
            $deadlineTime = $clockOutTime->copy()->addHours($deadlineHours);

            // If deadline hasn't passed yet, no violation
            if (Carbon::now()->lt($deadlineTime)) {
                return false;
            }
        }

        // Check for exemption conditions
        if (isset($config['exempt_conditions'])) {
            $exemptConditions = $config['exempt_conditions'];

            // Check for exemption based on attendance duration
            if (isset($exemptConditions['max_hours_for_exemption']) &&
                $attendance->clock_in_time && $attendance->clock_out_time) {

                $maxHoursForExemption = (float)$exemptConditions['max_hours_for_exemption'];
                $clockInTime = Carbon::parse($attendance->clock_in_time);
                $clockOutTime = Carbon::parse($attendance->clock_out_time);
                $durationHours = $clockInTime->diffInMinutes($clockOutTime) / 60;

                if ($durationHours <= $maxHoursForExemption) {
                    return false; // Exempt from verification due to short duration
                }
            }

            // Check for exemption based on user role
            if (isset($exemptConditions['exempt_roles']) && is_array($exemptConditions['exempt_roles'])) {
                $user = app(UserRepository::class)->find($attendance->user_id);
                if ($user && in_array($user->role, $exemptConditions['exempt_roles'])) {
                    return false; // Exempt from verification due to user role
                }
            }
        }

        // Determine verification type required
        $verificationType = $config['verification_type'] ?? 'standard';
        $verificationMessage = 'Office verification required for attendance record.';

        if ($verificationType === 'manager') {
            $verificationMessage = 'Manager verification required for attendance record.';
        } elseif ($verificationType === 'hr') {
            $verificationMessage = 'HR verification required for attendance record.';
        }

        // Return violation details
        return [
            'constraint_type' => AttendanceConstraint::COMPLIANCE_OFFICE_VERIFICATION,
            'severity' => $this->getSeverityFromConfig($config),
            'message' => $verificationMessage,
            'details' => [
                'verification_type' => $verificationType,
                'clock_out_time' => $attendance->clock_out_time,
                'verification_status' => $isVerified
            ]
        ];
    }

    /**
     * Helper method to check if a time is within a given range.
     *
     * @param string $time Time to check in HH:MM format
     * @param string $start Start time in HH:MM format
     * @param string $end End time in HH:MM format
     * @return bool True if time is within range, false otherwise
     */
    protected function isTimeWithinRange(string $time, string $start, string $end): bool
    {
        $timeMinutes = $this->timeToMinutes($time);
        $startMinutes = $this->timeToMinutes($start);
        $endMinutes = $this->timeToMinutes($end);

        // Handle overnight ranges (where end time is earlier than start time)
        if ($endMinutes < $startMinutes) {
            return $timeMinutes >= $startMinutes || $timeMinutes <= $endMinutes;
        }

        return $timeMinutes >= $startMinutes && $timeMinutes <= $endMinutes;
    }

    /**
     * Convert HH:MM time string to minutes since midnight.
     */
    protected function timeToMinutes(string $timeString): int
    {
        if (!preg_match('/^(\d{2}):(\d{2})$/', $timeString, $parts)) {
            // Return 0 or throw an exception for invalid format
            return 0;
        }
        return (int)$parts[1] * 60 + (int)$parts[2];
    }

    /**
     * Extract severity level from constraint configuration.
     *
     * @param array $config The constraint configuration
     * @return string The severity level (high, medium, low)
     */
    protected function getSeverityFromConfig(array $config): string
    {
        // Get severity from config or default to medium
        return $config['severity'] ?? 'medium';
    }
}
