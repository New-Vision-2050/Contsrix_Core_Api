{
	"info": {
		"_postman_id": "file-share-api-collection",
		"name": "File Share API",
		"description": "API endpoints for sharing files with users in the Archive Library module",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Share File",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{token}}",
						"type": "text"
					},
					{
						"key": "X-Tenant",
						"value": "{{tenant_id}}",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"file_id\": \"{{file_id}}\",\n    \"user_ids\": [\n        \"{{user_id_1}}\",\n        \"{{user_id_2}}\",\n        \"{{user_id_3}}\"\n    ]\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{base_url}}/api/files/share",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"files",
						"share"
					]
				},
				"description": "Share a file with multiple users. The file_id and user_ids will be synced in the file_shares table, and a share URL will be generated and sent to users via email."
			},
			"response": [
				{
					"name": "Success Response",
					"originalRequest": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							},
							{
								"key": "Authorization",
								"value": "Bearer eyJ0eXAiOiJKV1QiLCJhbGc...",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"file_id\": \"9d2f3a1b-4c5d-6e7f-8a9b-0c1d2e3f4a5b\",\n    \"user_ids\": [\n        \"8c1e2d3b-4a5b-6c7d-8e9f-0a1b2c3d4e5f\",\n        \"7b0c1d2e-3f4a-5b6c-7d8e-9f0a1b2c3d4e\"\n    ]\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/files/share",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"files",
								"share"
							]
						}
					},
					"status": "OK",
					"code": 200,
					"_postman_previewlanguage": "json",
					"header": [
						{
							"key": "Content-Type",
							"value": "application/json"
						}
					],
					"cookie": [],
					"body": "{\n    \"status\": true,\n    \"message\": \"File shared successfully\",\n    \"data\": {\n        \"file\": {\n            \"id\": \"9d2f3a1b-4c5d-6e7f-8a9b-0c1d2e3f4a5b\",\n            \"name\": \"Important Document.pdf\",\n            \"reference_number\": \"REF-2025-001\",\n            \"start_date\": \"2025-01-01\",\n            \"end_date\": \"2025-12-31\",\n            \"folder_id\": \"8c1e2d3b-4a5b-6c7d-8e9f-0a1b2c3d4e5f\",\n            \"access_type\": \"private\",\n            \"media_urls\": [\n                \"https://example.com/storage/files/document.pdf\"\n            ]\n        },\n        \"share_url\": \"https://example.com/api/shared-files/9d2f3a1b-4c5d-6e7f-8a9b-0c1d2e3f4a5b\",\n        \"shared_with_count\": 2\n    }\n}"
				},
				{
					"name": "Validation Error",
					"originalRequest": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							},
							{
								"key": "Authorization",
								"value": "Bearer eyJ0eXAiOiJKV1QiLCJhbGc...",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"file_id\": \"invalid-uuid\",\n    \"user_ids\": []\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/files/share",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"files",
								"share"
							]
						}
					},
					"status": "Unprocessable Entity",
					"code": 422,
					"_postman_previewlanguage": "json",
					"header": [
						{
							"key": "Content-Type",
							"value": "application/json"
						}
					],
					"cookie": [],
					"body": "{\n    \"message\": \"The given data was invalid.\",\n    \"errors\": {\n        \"file_id\": [\n            \"File ID must be a valid UUID\"\n        ],\n        \"user_ids\": [\n            \"At least one user must be selected\"\n        ]\n    }\n}"
				}
			]
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8000",
			"type": "string"
		},
		{
			"key": "token",
			"value": "your_bearer_token_here",
			"type": "string"
		},
		{
			"key": "tenant_id",
			"value": "your_tenant_id_here",
			"type": "string"
		},
		{
			"key": "file_id",
			"value": "9d2f3a1b-4c5d-6e7f-8a9b-0c1d2e3f4a5b",
			"type": "string"
		},
		{
			"key": "user_id_1",
			"value": "8c1e2d3b-4a5b-6c7d-8e9f-0a1b2c3d4e5f",
			"type": "string"
		},
		{
			"key": "user_id_2",
			"value": "7b0c1d2e-3f4a-5b6c-7d8e-9f0a1b2c3d4e",
			"type": "string"
		},
		{
			"key": "user_id_3",
			"value": "6a9b0c1d-2e3f-4a5b-6c7d-8e9f0a1b2c3d",
			"type": "string"
		}
	]
}
