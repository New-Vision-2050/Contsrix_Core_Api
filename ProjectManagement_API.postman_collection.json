					"originalRequest": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"project_type_id\": \"uuid-here\",\n    \"sub_project_type_id\": \"uuid-here\",\n    \"sub_sub_project_type_id\": \"uuid-here\",\n    \"name\": \"New Project\",\n    \"project_value\": 100000.50,\n    \"status\": 1\n}",
