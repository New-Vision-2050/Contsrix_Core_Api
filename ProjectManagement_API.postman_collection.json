						},
						{
							"key": "status",
							"value": "",
							"description": "Filter by status (-1, 0, 1)"
						}
					]
				}
			},
			"response": []
		},
		{
			"name": "Create Project",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Accept",
						"value": "application/json",
						"type": "text"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{token}}",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"project_type_id\": \"{{project_type_id}}\",\n    \"sub_project_type_id\": \"{{sub_project_type_id}}\",\n    \"sub_sub_project_type_id\": \"{{sub_sub_project_type_id}}\",\n    \"name\": \"New Project Name\",\n    \"responsible_employee_id\": \"{{employee_id}}\",\n    \"client_id\": \"{{client_id}}\",\n    \"project_classification_id\": \"{{classification_id}}\",\n    \"cost_center_branch_id\": \"{{branch_id}}\",\n    \"management_id\": \"{{management_id}}\",\n    \"currency_id\": \"{{currency_id}}\",\n    \"project_value\": 100000.50,\n    \"status\": 1\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{url}}/projects",
					"host": ["{{url}}"],
					"path": ["projects"]
				},
				"description": "Create a new project\n\n**Required Fields:**\n- project_type_id (uuid, required)\n- sub_project_type_id (uuid, required)\n- sub_sub_project_type_id (uuid, required)\n\n**Optional Fields:**\n- name (string, nullable)\n- responsible_employee_id (uuid, nullable)\n- client_id (uuid, nullable)\n- project_classification_id (uuid, nullable)\n- cost_center_branch_id (uuid, nullable)\n- management_id (uuid, nullable)\n- currency_id (uuid, nullable)\n- project_value (decimal, nullable)\n- status (integer: -1, 0, 1, default: 1)"
			},
