				"url": {
					"raw": "{{url}}/projects?page=1&per_page=15&name=&project_type_id=&status=",
					"host": ["{{url}}"],
					"path": ["projects"],
					"query": [
						{
							"key": "page",
							"value": "1",
							"description": "Page number"
						},
						{
							"key": "per_page",
							"value": "15",
							"description": "Items per page"
						},
						{
							"key": "name",
							"value": "",
							"description": "Search by project name"
						},
						{
							"key": "project_type_id",
							"value": "",
							"description": "Filter by project type ID"
						},
