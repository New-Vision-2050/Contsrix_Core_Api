{
	"info": {
		"_postman_id": "user-access-management-api",
		"name": "User Access Management API",
		"description": "API for managing user access to management hierarchies (branches) in the Constrix system. This collection includes endpoints for assigning users to branches, retrieving access information, and managing user permissions.",
