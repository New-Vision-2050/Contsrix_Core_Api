	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Automatically set authentication if not present",
					"if (!pm.request.headers.has('Authorization')) {",
					"    pm.request.headers.add({",
					"        key: 'Authorization',",
					"        value: 'Bearer ' + pm.environment.get('auth_token')",
					"    });",
					"}",
					"",
					"// Add company header if not present",
					"if (!pm.request.headers.has('X-Company-Id')) {",
					"    pm.request.headers.add({",
					"        key: 'X-Company-Id',",
					"        value: pm.environment.get('company_id')",
					"    });",
					"}"
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Basic response validation",
					"pm.test('Response status code is valid', function () {",
					"    pm.expect(pm.response.code).to.be.oneOf([200, 201, 204, 400, 401, 403, 404, 422, 500]);",
					"});",
					"",
					"pm.test('Response has correct content type', function () {",
					"    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
					"});",
					"",
					"// Success response validation",
					"if (pm.response.code >= 200 && pm.response.code < 300) {",
					"    pm.test('Success response has correct structure', function () {",
					"        const responseJson = pm.response.json();",
					"        pm.expect(responseJson).to.have.property('status');",
					"    });",
					"}"
				]
			}
		}
