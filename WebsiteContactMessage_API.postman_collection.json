{
	"info": {
		"_postman_id": "website-contact-message-api-collection",
		"name": "WebsiteContactMessage API",
		"description": "API endpoints for managing Website Contact Messages in WebsiteCMS module",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "List Website Contact Messages",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Accept",
						"value": "application/json",
						"type": "text"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{token}}",
						"type": "text"
					}
				],
				"url": {
					"raw": "{{url}}/website-contact-messages?page=1&per_page=15&name=&phone=&email=&status=",
					"host": ["{{url}}"],
					"path": ["website-contact-messages"],
					"query": [
						{
							"key": "page",
							"value": "1",
							"description": "Page number"
						},
						{
							"key": "per_page",
							"value": "15",
							"description": "Items per page"
						},
						{
							"key": "name",
							"value": "",
							"description": "Search by name"
						},
						{
							"key": "phone",
							"value": "",
							"description": "Search by phone"
						},
						{
							"key": "email",
							"value": "",
							"description": "Search by email"
						},
						{
							"key": "status",
							"value": "",
							"description": "Filter by status (0 or 1)"
						}
					]
				},
				"description": "Get paginated list of website contact messages with optional filters"
			},
			"response": []
		},
		{
			"name": "Create Website Contact Message",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Accept",
						"value": "application/json",
						"type": "text"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{token}}",
						"type": "text"
					}
				],
				"body": {
					"mode": "formdata",
					"formdata": [
						{
							"key": "name",
							"value": "John Doe",
							"type": "text",
							"description": "Contact name (required, max 255 characters)"
						},
						{
							"key": "phone",
							"value": "+1234567890",
							"type": "text",
							"description": "Contact phone (required, max 20 characters)"
						},
						{
							"key": "email",
							"value": "john.doe@example.com",
							"type": "text",
							"description": "Contact email (required, valid email format)"
						},
						{
							"key": "address",
							"value": "123 Main Street, City, Country",
							"type": "text",
							"description": "Contact address (nullable, max 500 characters)"
						},
						{
							"key": "status",
							"value": "0",
							"type": "text",
							"description": "Message status (nullable, 0 or 1, default: 0)"
						},
						{
							"key": "message",
							"value": "This is a test contact message from the website form.",
							"type": "text",
							"description": "Contact message (required)"
						}
					]
				},
				"url": {
					"raw": "{{url}}/website-contact-messages",
					"host": ["{{url}}"],
					"path": ["website-contact-messages"]
				},
				"description": "Create a new website contact message"
			},
			"response": []
		},
		{
			"name": "Get Website Contact Message",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Accept",
						"value": "application/json",
						"type": "text"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{token}}",
						"type": "text"
					}
				],
				"url": {
					"raw": "{{url}}/website-contact-messages/:id",
					"host": ["{{url}}"],
					"path": ["website-contact-messages", ":id"],
					"variable": [
						{
							"key": "id",
							"value": "{{message_id}}",
							"description": "Website Contact Message UUID"
						}
					]
				},
				"description": "Get a specific website contact message by ID"
			},
			"response": []
		},
		{
			"name": "Update Website Contact Message",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Accept",
						"value": "application/json",
						"type": "text"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{token}}",
						"type": "text"
					}
				],
				"body": {
					"mode": "formdata",
					"formdata": [
						{
							"key": "_method",
							"value": "PUT",
							"type": "text",
							"description": "Method spoofing for PUT request"
						},
						{
							"key": "name",
							"value": "Jane Smith",
							"type": "text",
							"description": "Contact name (nullable, max 255 characters)"
						},
						{
							"key": "phone",
							"value": "+9876543210",
							"type": "text",
							"description": "Contact phone (nullable, max 20 characters)"
						},
						{
							"key": "email",
							"value": "jane.smith@example.com",
							"type": "text",
							"description": "Contact email (nullable, valid email format)"
						},
						{
							"key": "address",
							"value": "456 Oak Avenue, Town, Country",
							"type": "text",
							"description": "Contact address (nullable, max 500 characters)"
						},
						{
							"key": "status",
							"value": "1",
							"type": "text",
							"description": "Message status (nullable, 0 or 1)"
						},
						{
							"key": "message",
							"value": "Updated contact message content.",
							"type": "text",
							"description": "Contact message (nullable)"
						}
					]
				},
				"url": {
					"raw": "{{url}}/website-contact-messages/:id",
					"host": ["{{url}}"],
					"path": ["website-contact-messages", ":id"],
					"variable": [
						{
							"key": "id",
							"value": "{{message_id}}",
							"description": "Website Contact Message UUID"
						}
					]
				},
				"description": "Update an existing website contact message"
			},
			"response": []
		},
		{
			"name": "Delete Website Contact Message",
			"request": {
				"method": "DELETE",
				"header": [
					{
						"key": "Accept",
						"value": "application/json",
						"type": "text"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{token}}",
						"type": "text"
					}
				],
				"url": {
					"raw": "{{url}}/website-contact-messages/:id",
					"host": ["{{url}}"],
					"path": ["website-contact-messages", ":id"],
					"variable": [
						{
							"key": "id",
							"value": "{{message_id}}",
							"description": "Website Contact Message UUID"
						}
					]
				},
				"description": "Delete a website contact message"
			},
			"response": []
		},
		{
			"name": "Export Website Contact Messages",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Accept",
						"value": "application/json",
						"type": "text"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{token}}",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"format\": \"xlsx\",\n    \"ids\": []\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{url}}/website-contact-messages/export",
					"host": ["{{url}}"],
					"path": ["website-contact-messages", "export"]
				},
				"description": "Export website contact messages to Excel or CSV. Leave ids empty to export all, or provide specific IDs to export selected messages."
			},
			"response": []
		}
	],
	"variable": [
		{
			"key": "url",
			"value": "http://localhost/api/v1",
			"type": "string"
		},
		{
			"key": "token",
			"value": "your-bearer-token-here",
			"type": "string"
		},
		{
			"key": "message_id",
			"value": "uuid-here",
			"type": "string"
		}
	]
}
