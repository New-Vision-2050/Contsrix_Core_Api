{
	"info": {
		"_postman_id": "website-theme-api-collection",
		"name": "WebsiteTheme API",
		"description": "API endpoints for managing Website Theme and Color Palettes in WebsiteCMS module",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Get Current Company Theme",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Accept",
						"value": "application/json",
						"type": "text"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{token}}",
						"type": "text"
					}
				],
				"url": {
					"raw": "{{url}}/website-themes/current-company",
					"host": ["{{url}}"],
					"path": ["website-themes", "current-company"]
				},
				"description": "Get the website theme for the current authenticated company including all color palettes and theme images"
			},
			"response": []
		},
		{
			"name": "Update Current Company Theme",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Accept",
						"value": "application/json",
						"type": "text"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{token}}",
						"type": "text"
					}
				],
				"body": {
					"mode": "formdata",
					"formdata": [
						{
							"key": "url",
							"value": "https://example.com",
							"type": "text",
							"description": "Website URL (nullable)"
						},
						{
							"key": "radius",
							"value": "8",
							"type": "text",
							"description": "Border radius in pixels (nullable, integer)"
						},
						{
							"key": "html_font_size",
							"value": "16",
							"type": "text",
							"description": "Base HTML font size in pixels (nullable, integer)"
						},
						{
							"key": "font_family",
							"value": "Roboto, Arial, sans-serif",
							"type": "text",
							"description": "Font family (nullable)"
						},
						{
							"key": "font_size",
							"value": "14px",
							"type": "text",
							"description": "Default font size (nullable)"
						},
						{
							"key": "font_weight_light",
							"value": "300",
							"type": "text",
							"description": "Light font weight (nullable)"
						},
						{
							"key": "font_weight_regular",
							"value": "400",
							"type": "text",
							"description": "Regular font weight (nullable)"
						},
						{
							"key": "font_weight_medium",
							"value": "500",
							"type": "text",
							"description": "Medium font weight (nullable)"
						},
						{
							"key": "font_weight_bold",
							"value": "700",
							"type": "text",
							"description": "Bold font weight (nullable)"
						},
						{
							"key": "color_palettes[0][slug]",
							"value": "primary",
							"type": "text",
							"description": "Color palette slug (required, unique per company)"
						},
						{
							"key": "color_palettes[0][name]",
							"value": "Primary Color",
							"type": "text",
							"description": "Color palette name (required)"
						},
						{
							"key": "color_palettes[0][primary]",
							"value": "#1976D2",
							"type": "text",
							"description": "Primary color hex code (nullable)"
						},
						{
							"key": "color_palettes[0][light]",
							"value": "#42A5F5",
							"type": "text",
							"description": "Light variant hex code (nullable)"
						},
						{
							"key": "color_palettes[0][dark]",
							"value": "#1565C0",
							"type": "text",
							"description": "Dark variant hex code (nullable)"
						},
						{
							"key": "color_palettes[0][contrast]",
							"value": "#FFFFFF",
							"type": "text",
							"description": "Contrast color hex code (nullable)"
						},
						{
							"key": "icon",
							"type": "file",
							"description": "Theme icon (nullable, max 2MB, formats: jpeg,png,jpg,gif,svg,webp)",
							"src": []
						}
					]
				},
				"url": {
					"raw": "{{url}}/website-themes/current-company",
					"host": ["{{url}}"],
					"path": ["website-themes", "current-company"]
				},
				"description": "Update the website theme for the current company. Creates theme if it doesn't exist. All fields are optional - only send fields you want to update."
			},
			"response": []
		}
	],
	"variable": [
		{
			"key": "url",
			"value": "http://localhost/api/v1",
			"type": "string"
		},
		{
			"key": "token",
			"value": "your-bearer-token-here",
			"type": "string"
		},
	]
}
