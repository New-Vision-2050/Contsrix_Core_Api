					"code": 200,
					"_postman_previewlanguage": "json",
					"header": [],
					"cookie": [],
					"body": "{\n    \"data\": [\n        {\n            \"title\": \"اجمالي عدد الوسطاء\",\n            \"total\": 127,\n            \"percentage\": 18\n        },\n        {\n            \"title\": \"الوسطاء المضافين اخر شهر\",\n            \"total\": 25,\n            \"percentage\": -14\n        },\n        {\n            \"title\": \"الوسطاء النشطيين\",\n            \"total\": 115,\n            \"percentage\": 12\n        },\n        {\n            \"title\": \"الوسطاء المعلقين\",\n            \"total\": 12,\n            \"percentage\": -8\n        }\n    ]\n}"
