						{
							"key": "status_client_request",
							"value": "accepted",
							"type": "text",
							"description": "Request status (nullable) - pending, rejected, accepted"
						},
						{
							"key": "service_ids[]",
							"value": "1",
							"type": "text",
							"description": "Service ID array (nullable)"
