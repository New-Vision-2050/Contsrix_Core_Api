							"description": "Term setting IDs with service relationship (nullable) - Format: [{term_service_id: int, term_ids: []}]"
						},
						{
							"key": "branch_id",
							"value": "",
							"type": "text",
							"description": "Branch ID (nullable)"
						},
						{
							"key": "management_id",
							"value": "",
							"type": "text",
							"description": "Management ID (nullable)"
						},
						{
							"key": "attachments[]",
							"type": "file",
							"description": "Additional attachments (nullable)",
							"src": []
						}
					]
				},
				"url": {
					"raw": "{{url}}/client_requests/client-requests/{{client_request_id}}",
					"host": ["{{url}}"],
					"path": ["client_requests", "client-requests", "{{client_request_id}}"]
				}
