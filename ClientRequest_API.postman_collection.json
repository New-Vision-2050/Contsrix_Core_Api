		{
			"name": "Create Client Request",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Accept",
						"value": "application/json",
						"type": "text"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{token}}",
						"type": "text"
					}
				],
				"body": {
					"mode": "formdata",
					"formdata": [
						{
							"key": "client_request_type_id",
							"value": "1",
							"type": "text",
							"description": "Client request type ID (required) - 1: عرض سعر, 2: اجتماع"
						},
						{
							"key": "client_request_receiver_from_id",
							"value": "1",
							"type": "text",
							"description": "Receiver from ID (required) - 1: رقم واتساب, 2: بريد الكتروني, 3: موظف, 4: الوسطاء"
						},
						{
							"key": "client_type",
							"value": "individual",
							"type": "text",
							"description": "Client type (required) - e.g., individual, company"
						},
						{
							"key": "client_id",
							"value": "{{client_id}}",
							"type": "text",
							"description": "Client UUID (required)"
						},
						{
							"key": "content",
							"value": "طلب عرض سعر لمشروع تربة وخرسانة",
							"type": "text",
							"description": "Request content (nullable)"
						},
						{
							"key": "status_client_request",
							"value": "pending",
							"type": "text",
							"description": "Request status (nullable, default: pending) - pending, rejected, accepted"
						},
						{
							"key": "service_ids[]",
							"value": "1",
							"type": "text",
							"description": "Service ID array (nullable) - 1: تربه وخرسانه"
						},
						{
							"key": "term_setting_ids",
							"value": "[{\"term_service_id\": 1, \"term_ids\": [1, 2, 3]}, {\"term_service_id\": 2, \"term_ids\": [4, 5, 6]}]",
							"type": "text",
							"description": "Term setting IDs with service relationship (nullable) - Format: [{term_service_id: int, term_ids: []}]"
						},
						{
							"key": "branch_id",
							"value": "",
							"type": "text",
							"description": "Branch ID from management_hierarchies (nullable)"
						},
						{
							"key": "management_id",
							"value": "",
							"type": "text",
							"description": "Management ID from management_hierarchies (nullable)"
						},
						{
							"key": "attachments[]",
							"type": "file",
							"description": "Attachments array (nullable, max 10MB, formats: pdf,doc,docx,xls,xlsx,jpg,jpeg,png,gif,svg,webp)",
							"src": []
						}
					],
					"description": "Note: term_setting_ids should be sent as a JSON string array of objects. Example: [{\"term_service_id\": 1, \"term_ids\": [1, 2, 3]}]"
				},
				"url": {
					"raw": "{{url}}/client_requests/client-requests",
					"host": ["{{url}}"],
					"path": ["client_requests", "client-requests"]
				}
			}
		},
		{
			"name": "Create Client Request (JSON)",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Accept",
						"value": "application/json",
						"type": "text"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{token}}",
						"type": "text"
					},
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"client_request_type_id\": 1,\n    \"client_request_receiver_from_id\": 1,\n    \"client_type\": \"individual\",\n    \"client_id\": \"{{client_id}}\",\n    \"content\": \"طلب عرض سعر لمشروع تربة وخرسانة\",\n    \"status_client_request\": \"pending\",\n    \"service_ids\": [1, 2],\n    \"term_setting_ids\": [\n        {\"term_service_id\": 1, \"term_ids\": [1, 2, 3]},\n        {\"term_service_id\": 2, \"term_ids\": [4, 5, 6]}\n    ],\n    \"branch_id\": 1,\n    \"management_id\": 2\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{url}}/client_requests/client-requests",
					"host": ["{{url}}"],
					"path": ["client_requests", "client-requests"]
				},
				"description": "Create a new client request using JSON body (no file uploads)"
			}
		},
