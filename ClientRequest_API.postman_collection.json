{
	"info": {
		"_postman_id": "client-request-api-collection",
		"name": "ClientRequest API",
		"description": "API endpoints for managing Client Requests in Constrix API",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "List Client Requests",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Accept",
						"value": "application/json",
						"type": "text"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{token}}",
						"type": "text"
					}
				],
				"url": {
					"raw": "{{url}}/client_requests/client-requests?page=1&per_page=15",
					"host": ["{{url}}"],
					"path": ["client_requests", "client-requests"],
					"query": [
						{
							"key": "page",
							"value": "1",
							"description": "Page number"
						},
						{
							"key": "per_page",
							"value": "15",
							"description": "Items per page (max: 100)"
						},
						{
							"key": "client_request_type_id",
							"value": "",
							"description": "Filter by request type ID (1: عرض سعر, 2: اجتماع)",
							"disabled": true
						},
						{
							"key": "client_request_receiver_from_id",
							"value": "",
							"description": "Filter by receiver from ID (1: واتساب, 2: بريد, 3: موظف, 4: وسطاء)",
							"disabled": true
						},
						{
							"key": "client_type",
							"value": "",
							"description": "Filter by client type (partial match)",
							"disabled": true
						},
						{
							"key": "client_id",
							"value": "",
							"description": "Filter by client UUID",
							"disabled": true
						},
						{
							"key": "status_client_request",
							"value": "",
							"description": "Filter by status (pending, rejected, accepted)",
							"disabled": true
						},
						{
							"key": "content",
							"value": "",
							"description": "Search in content (partial match)",
							"disabled": true
						},
						{
							"key": "term_setting_ids",
							"value": "",
							"description": "Filter by term setting IDs with service relationship - Format: [{term_service_id: int, term_ids: []}]",
							"disabled": true
						},
						{
							"key": "branch_id",
							"value": "",
							"description": "Filter by branch ID",
							"disabled": true
						},
						{
							"key": "management_id",
							"value": "",
							"description": "Filter by management ID",
							"disabled": true
						},
						{
							"key": "service_id",
							"value": "",
							"description": "Filter by service ID",
							"disabled": true
						},
						{
							"key": "date_from",
							"value": "",
							"description": "Filter from date (YYYY-MM-DD)",
							"disabled": true
						},
						{
							"key": "date_to",
							"value": "",
							"description": "Filter to date (YYYY-MM-DD)",
							"disabled": true
						},
						{
							"key": "pending",
							"value": "",
							"description": "Filter pending requests (true/false)",
							"disabled": true
						},
						{
							"key": "accepted",
							"value": "",
							"description": "Filter accepted requests (true/false)",
							"disabled": true
						},
						{
							"key": "rejected",
							"value": "",
							"description": "Filter rejected requests (true/false)",
							"disabled": true
						}
