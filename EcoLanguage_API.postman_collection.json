{
	"info": {
		"_postman_id": "eco-language-api-collection",
		"name": "EcoLanguage API Collection",
		"description": "Complete API collection for EcoLanguage module with upsert functionality",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Authentication",
			"item": [
				{
					"name": "Login",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"admin@example.com\",\n    \"password\": \"password\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/auth/login",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"auth",
								"login"
							]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "EcoLanguage Management",
			"item": [
				{
					"name": "Get All Languages",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{access_token}}"
							},
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/v1/ecommerce/languages?page=1&per_page=10",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"v1",
								"ecommerce",
								"languages"
							],
							"query": [
								{
									"key": "page",
									"value": "1"
								},
								{
									"key": "per_page",
									"value": "10"
								}
							]
						}
					},
					"response": []
				},
				{
					"name": "Get Language by ID",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{access_token}}"
							},
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/v1/ecommerce/languages/{{language_id}}",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"v1",
								"ecommerce",
								"languages",
								"{{language_id}}"
							]
						}
					},
					"response": []
				},
				{
					"name": "Create/Update Language (Upsert)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{access_token}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"company_id\": \"{{company_id}}\",\n    \"name\": \"English\",\n    \"code\": \"en\",\n    \"direction\": \"ltr\",\n    \"is_default\": true,\n    \"is_active\": true\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/ecommerce/languages",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"v1",
								"ecommerce",
								"languages"
							]
						}
					},
					"response": []
				},
				{
					"name": "Create Arabic Language",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{access_token}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"company_id\": \"{{company_id}}\",\n    \"name\": \"العربية\",\n    \"code\": \"ar\",\n    \"direction\": \"rtl\",\n    \"is_default\": false,\n    \"is_active\": true\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/ecommerce/languages",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"v1",
								"ecommerce",
								"languages"
							]
						}
					},
					"response": []
				},
				{
					"name": "Create Multiple Languages (Bulk)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{access_token}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"languages\": [\n        {\n            \"language_id\": \"{{english_language_id}}\",\n            \"is_default\": true,\n            \"is_active\": true\n        },\n        {\n            \"language_id\": \"{{arabic_language_id}}\",\n            \"is_default\": false,\n            \"is_active\": true\n        }\n    ]\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/ecommerce/languages",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"v1",
								"ecommerce",
								"languages"
							]
						}
					},
					"response": []
				},
				{
					"name": "Update Language Status",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{access_token}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"company_id\": \"{{company_id}}\",\n    \"name\": \"English\",\n    \"code\": \"en\",\n    \"direction\": \"ltr\",\n    \"is_default\": true,\n    \"is_active\": false\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/ecommerce/languages",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"v1",
								"ecommerce",
								"languages"
							]
						}
					},
					"response": []
				},
				{
					"name": "Delete Language",
					"request": {
						"method": "DELETE",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{access_token}}"
							},
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/v1/ecommerce/languages/{{language_id}}",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"v1",
								"ecommerce",
								"languages",
								"{{language_id}}"
							]
						}
					},
					"response": []
				},
				{
					"name": "Export Languages",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{access_token}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"format\": \"xlsx\",\n    \"filters\": {\n        \"is_active\": true\n    }\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/ecommerce/languages/export",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"v1",
								"ecommerce",
								"languages",
								"export"
							]
						}
					},
					"response": []
				}
			]
		}
	],
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					""
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					""
				]
			}
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8000",
			"type": "string"
		},
		{
			"key": "access_token",
			"value": "",
			"type": "string"
		},
		{
			"key": "company_id",
			"value": "",
			"type": "string"
		},
		{
			"key": "language_id",
			"value": "",
			"type": "string"
		},
		{
			"key": "english_language_id",
			"value": "",
			"type": "string"
		},
		{
			"key": "arabic_language_id",
			"value": "",
			"type": "string"
		}
	]
}
