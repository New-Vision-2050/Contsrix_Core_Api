    {
      "name": "Internal Procedure Settings",
      "description": "NEW: CRUD for child procedure settings (internal procedures) under a parent category. Each child has a `form` key and its own workflow steps.",
      "item": [
        {
          "name": "List Internal Procedures",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json", "type": "text" },
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
            ],
            "url": {
              "raw": "{{url}}/procedure-settings/{{procedure_setting_id}}/internal-procedures",
              "host": ["{{url}}"],
              "path": ["procedure-settings", "{{procedure_setting_id}}", "internal-procedures"]
            },
            "description": "List all child internal procedure settings under a parent category.\n\n**URL:** `{{procedure_setting_id}}` = PARENT category ProcedureSetting UUID (e.g., the 'employee_task' category row with `parent_id = NULL`)."
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"code\": \"SUCCESS_WITH_LIST_PAYLOAD_OBJECTS\",\n  \"message\": \"Internal procedure settings retrieved successfully\",\n  \"payload\": [\n    {\n      \"id\": \"child-uuid-1\",\n      \"name\": \"بدء المهمة\",\n      \"form\": \"start_task\",\n      \"conditions\": [],\n      \"sort_order\": 1,\n      \"appears_before_id\": null,\n      \"appears_after_id\": null,\n      \"is_active\": true\n    },\n    {\n      \"id\": \"child-uuid-2\",\n      \"name\": \"تمديد وقت المهمة\",\n      \"form\": \"extend_task_time\",\n      \"conditions\": [{ \"key\": \"AllowDuringShift\", \"value\": true }],\n      \"sort_order\": 2,\n      \"appears_before_id\": null,\n      \"appears_after_id\": null,\n      \"is_active\": true\n    }\n  ]\n}"
            }
          ]
        },
        {
          "name": "Get Internal Procedure by Form",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json", "type": "text" },
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
            ],
            "url": {
              "raw": "{{url}}/procedure-settings/{{procedure_setting_id}}/internal-procedures/by-form/start_task",
              "host": ["{{url}}"],
              "path": ["procedure-settings", "{{procedure_setting_id}}", "internal-procedures", "by-form", "start_task"]
            },
            "description": "Get a single internal procedure setting by its form key under a parent.\n\n**URL:**\n- `{{procedure_setting_id}}` = PARENT category UUID\n- `start_task` = the form key (e.g., start_task, extend_task_time, send_for_approval, etc.)\n\n**Note:** If multiple children share the same form, this returns the FIRST match. For precise selection, use the child UUID."
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"code\": \"SUCCESS_WITH_SINGLE_PAYLOAD_OBJECT\",\n  \"message\": \"Internal procedure setting retrieved successfully\",\n  \"payload\": {\n    \"id\": \"child-uuid-1\",\n    \"name\": \"بدء المهمة\",\n    \"form\": \"start_task\",\n    \"conditions\": [],\n    \"sort_order\": 1,\n    \"appears_before_id\": null,\n    \"appears_after_id\": null,\n    \"is_active\": true,\n    \"steps\": []\n  }\n}"
            }
          ]
        },
        {
          "name": "Create Internal Procedure",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json", "type": "text" },
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"تأكيد خروج الموقع\",\n  \"form\": \"confirm_location\",\n  \"conditions\": [\n    { \"key\": \"ApplyToAllBranches\", \"value\": true }\n  ],\n  \"appears_before_id\": null,\n  \"appears_after_id\": \"child-uuid-of-enter-location\",\n  \"sort_order\": 3,\n  \"is_active\": true\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{url}}/procedure-settings/{{procedure_setting_id}}/internal-procedures",
              "host": ["{{url}}"],
              "path": ["procedure-settings", "{{procedure_setting_id}}", "internal-procedures"]
            },
            "description": "Create a new internal procedure setting (child) under a parent category.\n\n**URL:** `{{procedure_setting_id}}` = The PARENT category ProcedureSetting UUID (the row with `parent_id = NULL`, `type = 'employee_task'`).\n\n**Body:** You send `name`, `form`, `conditions`, etc. You do NOT send `internal_procedure_setting_id` — the server generates the child UUID automatically and returns it in the response.\n\n**Example:** To create 'بدء مهمة العمل' under the 'employee_task' category:\n- `procedure_setting_id` in URL = UUID of the 'employee_task' parent row\n- Body `form` = `start_task`\n- Response `payload.id` = the new `internal_procedure_setting_id`\n\n`form` must be one of: start_task, extend_task_time, send_for_approval, cancel_task, confirm_location, assign_other_employee, attach_attachments"
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"code\": \"SUCCESS_WITH_SINGLE_PAYLOAD_OBJECT\",\n  \"message\": \"Internal procedure setting created successfully\",\n  \"payload\": {\n    \"id\": \"new-child-uuid\",\n    \"name\": \"تأكيد خروج الموقع\",\n    \"form\": \"confirm_location\",\n    \"conditions\": [{ \"key\": \"ApplyToAllBranches\", \"value\": true }],\n    \"sort_order\": 3,\n    \"appears_before_id\": null,\n    \"appears_after_id\": \"child-uuid-of-enter-location\"\n  }\n}"
            }
          ]
        },
        {
          "name": "Update Internal Procedure",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Accept", "value": "application/json", "type": "text" },
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"تأكيد خروج الموقع - نهائي\",\n  \"form\": \"confirm_location\",\n  \"conditions\": [\n    { \"key\": \"ApplyToAllBranches\", \"value\": true }\n  ],\n  \"appears_before_id\": null,\n  \"appears_after_id\": \"child-uuid-of-enter-location\",\n  \"sort_order\": 3,\n  \"is_active\": true\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{url}}/procedure-settings/{{procedure_setting_id}}/internal-procedures/{{internal_procedure_setting_id}}",
              "host": ["{{url}}"],
              "path": ["procedure-settings", "{{procedure_setting_id}}", "internal-procedures", "{{internal_procedure_setting_id}}"]
            },
            "description": "Update an existing internal procedure setting (child).\n\n**URL:**\n- `{{procedure_setting_id}}` = PARENT category UUID\n- `{{internal_procedure_setting_id}}` = CHILD internal procedure UUID (the one you are updating)"
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"code\": \"SUCCESS_WITH_SINGLE_PAYLOAD_OBJECT\",\n  \"message\": \"Internal procedure setting updated successfully\",\n  \"payload\": {\n    \"id\": \"new-child-uuid\",\n    \"name\": \"تأكيد خروج الموقع - نهائي\",\n    \"form\": \"confirm_location\"\n  }\n}"
            }
          ]
        },
        {
          "name": "Delete Internal Procedure",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Accept", "value": "application/json", "type": "text" },
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
            ],
            "url": {
              "raw": "{{url}}/procedure-settings/{{procedure_setting_id}}/internal-procedures/{{internal_procedure_setting_id}}",
