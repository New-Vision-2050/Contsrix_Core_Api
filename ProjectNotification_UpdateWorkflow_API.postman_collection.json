              "type": "text",
              "description": "اسم المقاول"
            },
            {
              "key": "contractor_technical_name",
              "value": "منسق المقاول",
              "type": "text",
              "description": "مني المقاول"
            },
            {
              "key": "contractor_mobile",
              "value": "0500000000",
              "type": "text",
              "description": "رقم الجوال"
            },
            {
              "key": "task_latitude",
              "value": "24.7136",
              "type": "text",
              "description": "خط العرض"
            },
            {
              "key": "task_longitude",
              "value": "46.6753",
              "type": "text",
              "description": "خط الطول"
            },
            {
              "key": "notes",
              "value": "سبب التعديل",
              "type": "text",
              "description": "سبب التعديل"
            },
            {
              "key": "internal_procedure_setting_id",
              "value": "{{internal_procedure_setting_id}}",
              "type": "text",
              "description": "Optional specific internal procedure setting ID"
            },
            {
              "key": "files",
              "type": "file",
              "description": "صور الإشعار (jpeg, png, webp, max 10MB)",
              "src": []
            },
            {
              "key": "files",
              "type": "file",
              "description": "صور الإشعار (jpeg, png, webp, max 10MB)",
              "src": []
            }
          ]
        },
        "url": {
