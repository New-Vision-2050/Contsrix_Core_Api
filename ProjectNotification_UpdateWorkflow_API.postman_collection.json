{
  "info": {
    "_postman_id": "project-notification-update-workflow-collection",
    "name": "Project Notification Update Workflow API",
    "description": "Workflow-based update for project notifications.\n\nFlow:\n1. POST /projects/notifications/{id}/request-update → submit new data + files (creates a Process).\n2. Approver sees the pending Process step in their inbox.\n3. POST /projects/notifications/{id}/approve → approves the current step.\n4. On final approval the ProjectNotification row is updated with the submitted data and files are moved to the attachments collection.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "url",
      "value": "http://localhost/api/v1",
      "type": "string"
    },
    {
      "key": "token",
      "value": "your-bearer-token-here",
      "type": "string"
    },
    {
      "key": "notification_id",
      "value": "uuid-here",
      "type": "string"
    },
    {
      "key": "internal_procedure_setting_id",
      "value": "uuid-of-updateProjectNotificationTask-internal-procedure",
      "type": "string",
      "description": "Optional: specific UpdateProjectNotificationTask internal procedure setting ID."
    },
    {
      "key": "site_status_id",
      "value": "uuid-of-site-status",
      "type": "string",
      "description": "Site status ID from GET /projects/notifications/site-statuses"
    },
    {
      "key": "current_site_status_id",
      "value": "uuid-of-current-site-status",
      "type": "string",
      "description": "Current site status ID from GET /projects/notifications/site-statuses"
    },
    {
      "key": "work_stoppage_reason_id",
      "value": "uuid-of-work-stoppage-reason",
      "type": "string",
      "description": "Work stoppage reason ID from GET /projects/notifications/work-stoppage-reasons"
    },
    {
      "key": "procedure_setting_id",
      "value": "uuid-of-internal-procedure-setting",
      "type": "string",
      "description": "Internal procedure setting ID for the active workflow step"
    }
  ],
  "item": [
